#!/bin/bash
# intent_ext - Manage Intent user extensions at ~/.intent/ext/<name>/
# Copyright (c) 2026 Matthew Sinclair
# Licensed under the MIT License (see LICENSE file)
# Usage: intent ext [list|show|validate|new] [options]

set -e

# ---- Bootstrap ----
: "${INTENT_HOME:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$INTENT_HOME/bin/intent_helpers"

# ---- Ext root resolution ----
# Honours INTENT_EXT_DIR (used by tests) and INTENT_EXT_DISABLE=1
ext_root_dir() {
  if [ "${INTENT_EXT_DISABLE:-}" = "1" ]; then
    echo ""
    return 0
  fi
  echo "${INTENT_EXT_DIR:-$HOME/.intent/ext}"
}

# Enumerate extension directory names under the ext root (dotfiles and _*
# excluded). Output one name per line.
ext_enumerate_names() {
  local root
  root="$(ext_root_dir)"
  [ -z "$root" ] && return 0
  [ -d "$root" ] || return 0

  local ext_dir name
  for ext_dir in "$root"/*/; do
    [ -d "$ext_dir" ] || continue
    name="$(basename "$ext_dir")"
    case "$name" in
      .*|_*) continue ;;
    esac
    echo "$name"
  done
}

# Classify an extension by inspecting its manifest.
# Outputs one of: valid | malformed | missing-manifest
ext_status() {
  local name="$1"
  local root
  root="$(ext_root_dir)"
  local manifest="$root/$name/extension.json"

  if [ ! -f "$manifest" ]; then
    echo "missing-manifest"
    return 0
  fi

  # jq must parse the file AND it must declare a schema of intent-extension/v1
  local schema
  schema=$(jq -r '.schema // empty' "$manifest" 2>/dev/null) || {
    echo "malformed"
    return 0
  }

  if [ -z "$schema" ] || [ "$schema" != "intent-extension/v1" ]; then
    echo "malformed"
    return 0
  fi

  # name and version are mandatory for minimum viability
  local mname mver
  mname=$(jq -r '.name // empty' "$manifest" 2>/dev/null)
  mver=$(jq -r '.version // empty' "$manifest" 2>/dev/null)
  if [ -z "$mname" ] || [ -z "$mver" ]; then
    echo "malformed"
    return 0
  fi

  echo "valid"
}

# Read a jq expression from an extension's manifest. Silently echoes empty on
# parse failure.
ext_manifest_get() {
  local name="$1"
  local expr="$2"
  local root
  root="$(ext_root_dir)"
  local manifest="$root/$name/extension.json"
  [ -f "$manifest" ] || return 0
  jq -r "$expr" "$manifest" 2>/dev/null || true
}

# ---- Subcommand: list ----
ext_list() {
  local root
  root="$(ext_root_dir)"

  if [ -z "$root" ]; then
    echo "ok: ext discovery disabled (INTENT_EXT_DISABLE=1)"
    return 0
  fi

  if [ ! -d "$root" ]; then
    echo "ok: no extensions installed ($root does not exist)"
    return 0
  fi

  require_jq || return 1

  local names
  names=$(ext_enumerate_names)

  if [ -z "$names" ]; then
    echo "ok: no extensions installed ($root is empty)"
    return 0
  fi

  local term_width
  term_width=$(get_terminal_width 2>/dev/null || echo 100)

  echo "Extensions in $root:"
  echo ""

  local name status version description line
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    status="$(ext_status "$name")"
    version="$(ext_manifest_get "$name" '.version // "?"')"
    description="$(ext_manifest_get "$name" '.description // ""')"

    case "$status" in
      valid)        line="$(printf "  %-20s %-10s %s" "$name" "$version" "$description")" ;;
      malformed)    line="$(printf "  %-20s %-10s [malformed manifest]" "$name" "$version")" ;;
      missing-manifest)
                    line="$(printf "  %-20s %-10s [missing extension.json]" "$name" "-")" ;;
      *)            line="$(printf "  %-20s %-10s [%s]" "$name" "$version" "$status")" ;;
    esac
    echo "$line"
  done <<< "$names"

  echo ""
  echo "run: intent ext show <name>   for details"
}

# ---- Subcommand: show ----
# Emit a shadow warning for a canon subagent or skill overridden by an ext.
ext_show_shadow_warning() {
  local type="$1"  # "subagent" or "skill"
  local ext_name="$2"
  local contrib_name="$3"
  local canon_path

  case "$type" in
    subagents|subagent)
      canon_path="$INTENT_HOME/intent/plugins/claude/subagents/$contrib_name/agent.md"
      if [ -f "$canon_path" ]; then
        echo "  warning: subagent '$contrib_name' shadows canon" >&2
      fi
      ;;
    skills|skill)
      canon_path="$INTENT_HOME/intent/plugins/claude/skills/$contrib_name/SKILL.md"
      if [ -f "$canon_path" ]; then
        echo "  warning: skill '$contrib_name' shadows canon" >&2
      fi
      ;;
  esac
  return 0
}

ext_show() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "error: extension name required" >&2
    echo "usage: intent ext show <name>" >&2
    return 1
  fi

  local root
  root="$(ext_root_dir)"
  if [ -z "$root" ]; then
    echo "error: ext discovery disabled (INTENT_EXT_DISABLE=1)" >&2
    return 1
  fi

  local ext_dir="$root/$name"
  if [ ! -d "$ext_dir" ]; then
    echo "error: extension '$name' not found at $ext_dir" >&2
    return 1
  fi

  require_jq || return 1

  local status
  status="$(ext_status "$name")"

  echo "Extension: $name"
  echo "  Location:     $ext_dir"
  echo "  Status:       $status"

  if [ "$status" != "valid" ]; then
    if [ "$status" = "missing-manifest" ]; then
      echo ""
      echo "error: $ext_dir/extension.json is absent"
      return 1
    fi
    if [ "$status" = "malformed" ]; then
      echo ""
      echo "error: $ext_dir/extension.json is malformed (schema, name, or version missing)"
      return 1
    fi
  fi

  echo "  Version:      $(ext_manifest_get "$name" '.version // "?"')"
  echo "  Author:       $(ext_manifest_get "$name" '.author // "unknown"')"
  echo "  License:      $(ext_manifest_get "$name" '.license // "unspecified"')"
  echo "  Homepage:     $(ext_manifest_get "$name" '.homepage // "n/a"')"
  echo "  Description:  $(ext_manifest_get "$name" '.description // ""')"

  local compat_min compat_max
  compat_min="$(ext_manifest_get "$name" '.intent_compat.min // "?"')"
  compat_max="$(ext_manifest_get "$name" '.intent_compat.max // "?"')"
  echo "  Intent compat: min=$compat_min max=$compat_max"
  echo ""

  # Contributions breakdown
  local subagents_count skills_count rules_count
  subagents_count=$(ext_manifest_get "$name" '.contributes.subagents // [] | length')
  skills_count=$(ext_manifest_get "$name" '.contributes.skills // [] | length')
  rules_count=$(ext_manifest_get "$name" '.contributes.rules // [] | length')
  subagents_count="${subagents_count:-0}"
  skills_count="${skills_count:-0}"
  rules_count="${rules_count:-0}"

  echo "Contributes:"
  echo "  subagents: $subagents_count"
  echo "  skills:    $skills_count"
  echo "  rules:     $rules_count"

  local i contrib_name contrib_path

  if [ "$subagents_count" -gt 0 ]; then
    echo ""
    echo "Subagents:"
    i=0
    while [ "$i" -lt "$subagents_count" ]; do
      contrib_name="$(ext_manifest_get "$name" ".contributes.subagents[$i].name // \"?\"")"
      contrib_path="$(ext_manifest_get "$name" ".contributes.subagents[$i].path // \"?\"")"
      echo "  - $contrib_name  ($contrib_path)"
      ext_show_shadow_warning "subagents" "$name" "$contrib_name"
      i=$((i + 1))
    done
  fi

  if [ "$skills_count" -gt 0 ]; then
    echo ""
    echo "Skills:"
    i=0
    while [ "$i" -lt "$skills_count" ]; do
      contrib_name="$(ext_manifest_get "$name" ".contributes.skills[$i].name // \"?\"")"
      contrib_path="$(ext_manifest_get "$name" ".contributes.skills[$i].path // \"?\"")"
      echo "  - $contrib_name  ($contrib_path)"
      ext_show_shadow_warning "skills" "$name" "$contrib_name"
      i=$((i + 1))
    done
  fi

  if [ "$rules_count" -gt 0 ]; then
    echo ""
    echo "Rules:"
    i=0
    while [ "$i" -lt "$rules_count" ]; do
      contrib_name="$(ext_manifest_get "$name" ".contributes.rules[$i].name // \"?\"")"
      contrib_path="$(ext_manifest_get "$name" ".contributes.rules[$i].path // \"?\"")"
      echo "  - $contrib_name  ($contrib_path)"
      i=$((i + 1))
    done
  fi
}

# ---- Subcommand: validate ----
# Validate one extension by name. Prints per-issue lines indented under the
# caller-provided banner. Returns 0 when clean, 1 when any error accumulated.
ext_validate_one() {
  local name="$1"
  local root
  root="$(ext_root_dir)"
  local ext_dir="$root/$name"
  local manifest="$ext_dir/extension.json"
  local errors=0

  if [ ! -d "$ext_dir" ]; then
    echo "  error: $ext_dir does not exist"
    return 1
  fi

  if [ ! -f "$manifest" ]; then
    echo "  error: extension.json missing"
    return 1
  fi

  if ! jq -e . "$manifest" >/dev/null 2>&1; then
    echo "  error: extension.json is not valid JSON"
    return 1
  fi

  # Required top-level fields
  local schema mname mversion
  schema=$(jq -r '.schema // empty' "$manifest" 2>/dev/null || echo "")
  mname=$(jq -r '.name // empty' "$manifest" 2>/dev/null || echo "")
  mversion=$(jq -r '.version // empty' "$manifest" 2>/dev/null || echo "")

  if [ -z "$schema" ]; then
    echo "  error: missing required field 'schema'"
    errors=$((errors + 1))
  elif [ "$schema" != "intent-extension/v1" ]; then
    echo "  error: schema must be 'intent-extension/v1', got '$schema'"
    errors=$((errors + 1))
  fi

  if [ -z "$mname" ]; then
    echo "  error: missing required field 'name'"
    errors=$((errors + 1))
  else
    if [ "$mname" != "$name" ]; then
      echo "  error: manifest name '$mname' does not match directory '$name'"
      errors=$((errors + 1))
    fi
    if ! echo "$mname" | grep -qE '^[a-z0-9][a-z0-9-]*$'; then
      echo "  error: name '$mname' must match ^[a-z0-9][a-z0-9-]*$"
      errors=$((errors + 1))
    fi
  fi

  if [ -z "$mversion" ]; then
    echo "  error: missing required field 'version'"
    errors=$((errors + 1))
  elif ! echo "$mversion" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+(-[A-Za-z0-9.-]+)?$'; then
    echo "  error: version '$mversion' must match semver (MAJOR.MINOR.PATCH[-PRERELEASE])"
    errors=$((errors + 1))
  fi

  # Reject unknown top-level keys (schema is additionalProperties:false)
  local known='["schema","name","version","description","author","license","homepage","intent_compat","contributes","checksums"]'
  local unknown_keys
  unknown_keys=$(jq -r --argjson known "$known" 'keys - $known | .[]' "$manifest" 2>/dev/null || true)
  if [ -n "$unknown_keys" ]; then
    local uk
    while IFS= read -r uk; do
      [ -z "$uk" ] && continue
      echo "  error: unknown top-level field '$uk' (schema disallows additional properties)"
      errors=$((errors + 1))
    done <<< "$unknown_keys"
  fi

  # intent_compat.min compatibility with current Intent
  local compat_min
  compat_min=$(jq -r '.intent_compat.min // empty' "$manifest" 2>/dev/null || echo "")
  if [ -n "$compat_min" ]; then
    local current_ver
    current_ver=$(get_intent_version 2>/dev/null || echo "2.9.0")
    local lowest
    lowest=$(printf '%s\n%s\n' "$compat_min" "$current_ver" | sort -V | head -1)
    if [ "$lowest" != "$compat_min" ]; then
      echo "  error: intent_compat.min='$compat_min' exceeds current Intent version '$current_ver'"
      errors=$((errors + 1))
    fi
  fi

  # Contributions: path traversal + file existence
  local type count idx cname cpath expected_file
  for type in subagents skills rules; do
    count=$(jq ".contributes.${type} // [] | length" "$manifest" 2>/dev/null || echo 0)
    count="${count:-0}"
    idx=0
    while [ "$idx" -lt "$count" ]; do
      cname=$(jq -r ".contributes.${type}[$idx].name // empty" "$manifest" 2>/dev/null || echo "")
      cpath=$(jq -r ".contributes.${type}[$idx].path // empty" "$manifest" 2>/dev/null || echo "")

      if [ -z "$cname" ]; then
        echo "  error: contributes.${type}[$idx].name missing"
        errors=$((errors + 1))
      fi

      if [ -z "$cpath" ]; then
        echo "  error: contributes.${type}[$idx].path missing"
        errors=$((errors + 1))
        idx=$((idx + 1))
        continue
      fi

      # Path traversal: reject absolute paths and '..' segments
      if [[ "$cpath" = /* ]]; then
        echo "  error: contributes.${type}[$idx].path '$cpath' is absolute (rejected)"
        errors=$((errors + 1))
        idx=$((idx + 1))
        continue
      fi

      case "/$cpath/" in
        */../*)
          echo "  error: contributes.${type}[$idx].path '$cpath' contains '..' (path traversal rejected)"
          errors=$((errors + 1))
          idx=$((idx + 1))
          continue
          ;;
      esac

      # Contribution file presence
      case "$type" in
        subagents) expected_file="$ext_dir/$cpath/agent.md" ;;
        skills)    expected_file="$ext_dir/$cpath/SKILL.md" ;;
        rules)     expected_file="$ext_dir/$cpath/RULE.md" ;;
      esac

      if [ ! -f "$expected_file" ]; then
        echo "  error: contributes.${type}[$idx] expects $expected_file (missing)"
        errors=$((errors + 1))
      fi

      idx=$((idx + 1))
    done
  done

  if [ "$errors" -eq 0 ]; then
    return 0
  fi
  return 1
}

ext_validate() {
  local target_name="${1:-}"
  local root
  root="$(ext_root_dir)"
  if [ -z "$root" ]; then
    echo "error: ext discovery disabled (INTENT_EXT_DISABLE=1)" >&2
    return 1
  fi
  if [ ! -d "$root" ]; then
    echo "ok: no extensions to validate ($root does not exist)"
    return 0
  fi

  require_jq || return 1

  local names
  if [ -n "$target_name" ]; then
    local target_dir="$root/$target_name"
    if [ ! -d "$target_dir" ]; then
      echo "error: extension '$target_name' not found at $target_dir" >&2
      return 1
    fi
    names="$target_name"
  else
    names="$(ext_enumerate_names)"
  fi

  if [ -z "$names" ]; then
    echo "ok: no extensions to validate ($root is empty)"
    return 0
  fi

  local total=0 ok_count=0 fail_count=0
  local name

  while IFS= read -r name; do
    [ -z "$name" ] && continue
    total=$((total + 1))
    echo "$name:"
    if ext_validate_one "$name"; then
      ok_count=$((ok_count + 1))
      echo "  ok"
    else
      fail_count=$((fail_count + 1))
    fi
  done <<< "$names"

  echo ""
  echo "summary: $total checked, $ok_count ok, $fail_count failed"

  if [ "$fail_count" -gt 0 ]; then
    return 1
  fi
  return 0
}

# ---- Subcommand: new ----
# Emit an extension.json tailored to a single contribution type.
ext_new_manifest() {
  local name="$1"
  local type="$2"   # subagent | skill | rule-pack
  local intent_ver
  intent_ver=$(get_intent_version 2>/dev/null || echo "2.8.0")

  local contributes
  case "$type" in
    subagent)
      contributes=$(jq -n --arg n "$name" '{
        subagents: [ { name: $n, path: ("subagents/" + $n) } ],
        skills: [],
        rules: []
      }')
      ;;
    skill)
      contributes=$(jq -n --arg n "$name" '{
        subagents: [],
        skills: [ { name: $n, path: ("skills/" + $n) } ],
        rules: []
      }')
      ;;
    rule-pack)
      # Rule-pack scaffolds at least one sample agnostic rule so the
      # generated extension passes ext validate immediately.
      local rule_id
      rule_id="IN-AG-EXT-$(echo "$name" | tr '[:lower:]' '[:upper:]')-001"
      contributes=$(jq -n --arg id "$rule_id" --arg n "$name" '{
        subagents: [],
        skills: [],
        rules: [ { name: $id, path: ("rules/agnostic/" + $n + "-sample") } ]
      }')
      ;;
    *)
      echo "error: unknown type '$type' (expected subagent | skill | rule-pack)" >&2
      return 1
      ;;
  esac

  jq -n \
    --arg name "$name" \
    --arg min "$intent_ver" \
    --argjson contributes "$contributes" \
    '{
      schema: "intent-extension/v1",
      name: $name,
      version: "0.1.0",
      description: ("User extension: " + $name),
      author: "",
      license: "MIT",
      intent_compat: { min: $min, max: "3.x" },
      contributes: $contributes
    }'
}

ext_new_readme() {
  local name="$1"
  local type="$2"

  local edit_path install_hint
  case "$type" in
    subagent)
      edit_path="subagents/$name/agent.md"
      install_hint="Install via \`intent claude subagents install $name\`."
      ;;
    skill)
      edit_path="skills/$name/SKILL.md"
      install_hint="Install via \`intent claude skills install $name\`."
      ;;
    rule-pack)
      edit_path="rules/agnostic/$name-sample/RULE.md"
      install_hint="Rules are consumed by \`critic-*\` subagents and do not need a separate install step."
      ;;
  esac

  cat << EOF
# $name

User-local Intent extension ($type). Scaffolded by \`intent ext new\`.

## What this is

A self-contained directory installed at \`\$INTENT_EXT_DIR/$name/\` (default \`~/.intent/ext/$name/\`) that contributes a $type into Intent without modifying canon. See \`intent help ext\` and \`intent/docs/writing-extensions.md\` for authoring guidance.

## Next steps

1. Edit the placeholder contribution under \`$edit_path\` to describe what your extension actually does.
2. Update the \`author\` and \`description\` fields in \`extension.json\`.
3. Run \`intent ext validate $name\` to confirm the manifest is well-formed.
4. $install_hint
EOF
}

ext_new_placeholder_agent() {
  local name="$1"
  cat << EOF
---
name: $name
description: Placeholder ext subagent scaffolded by 'intent ext new'
tools: []
---

# $name

Describe what this subagent does, its inputs and outputs, and when to invoke it.

## Responsibilities

- Replace this placeholder with the agent's system prompt.

## Invocation

- \`Task(subagent_type="$name", prompt="...")\`
EOF
}

ext_new_placeholder_metadata() {
  local name="$1"
  jq -n --arg n "$name" '{
    name: $n,
    version: "0.1.0",
    description: ("Placeholder ext subagent: " + $n),
    author: "",
    tools: [],
    tags: []
  }'
}

ext_new_placeholder_skill() {
  local name="$1"
  cat << EOF
---
name: $name
description: Placeholder ext skill scaffolded by 'intent ext new'
---

# $name

Describe the coding discipline this skill enforces and when Claude should load it.

## Procedure

1. Replace this placeholder with your skill's step-by-step instructions.

## Red Flags

| Rationalization     | Reality |
| ------------------- | ------- |
| "This will do for now" | Placeholder content ships; refine before publishing. |
EOF
}

ext_new_placeholder_rule() {
  local rule_id="$1"
  local ext_name="$2"
  cat << EOF
---
id: $rule_id
title: Sample ext rule
language: agnostic
category: ext
severity: recommendation
summary: Placeholder ext rule scaffolded by 'intent ext new'. Replace this summary.
principles: []
applies_to: []
applies_when: []
does_not_apply_when: []
upstream_id: null
references: []
related_rules: []
concretised_by: []
aliases: []
tags: ["ext", "$ext_name"]
sources: []
conflicts_with: []
status: active
version: 1
---

# Sample ext rule

Describe the principle or antipattern this rule encodes.

## Problem

Placeholder.

## Detection

Placeholder.

## Bad

Placeholder.

## Good

Placeholder.

## When This Applies

Placeholder.

## When This Does Not Apply

Placeholder.

## Further Reading

- \`intent help rules\` (WP10)
EOF
}

ext_new() {
  local name=""
  local type=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --subagent)   type="subagent"; shift ;;
      --skill)      type="skill"; shift ;;
      --rule-pack)  type="rule-pack"; shift ;;
      --help|-h)
        cat << 'EOF'
Usage: intent ext new <name> --subagent | --skill | --rule-pack

Scaffolds a self-contained extension under $INTENT_EXT_DIR/<name>/ (or
~/.intent/ext/<name>/ by default) with a manifest and one placeholder
contribution of the chosen type.

The generated extension passes 'intent ext validate <name>' immediately.

Examples:
  intent ext new hello-world --subagent
  intent ext new hello-world --skill
  intent ext new hello-rules --rule-pack
EOF
        return 0
        ;;
      --*)
        echo "error: unknown flag '$1'" >&2
        return 1
        ;;
      *)
        if [ -z "$name" ]; then
          name="$1"
        else
          echo "error: unexpected argument '$1'" >&2
          return 1
        fi
        shift
        ;;
    esac
  done

  if [ -z "$name" ]; then
    echo "error: extension name required" >&2
    echo "usage: intent ext new <name> --subagent | --skill | --rule-pack" >&2
    return 1
  fi

  if [ -z "$type" ]; then
    echo "error: --subagent, --skill, or --rule-pack required" >&2
    return 1
  fi

  if ! echo "$name" | grep -qE '^[a-z0-9][a-z0-9-]*$'; then
    echo "error: name '$name' must match ^[a-z0-9][a-z0-9-]*$ (lowercase, digits, hyphens)" >&2
    return 1
  fi

  local root
  root="$(ext_root_dir)"
  if [ -z "$root" ]; then
    echo "error: ext discovery disabled (INTENT_EXT_DISABLE=1)" >&2
    return 1
  fi

  local target="$root/$name"
  if [ -e "$target" ]; then
    echo "error: $target already exists (refusing to overwrite)" >&2
    return 1
  fi

  require_jq || return 1

  mkdir -p "$target"

  ext_new_manifest "$name" "$type" > "$target/extension.json"
  ext_new_readme "$name" "$type" > "$target/README.md"

  case "$type" in
    subagent)
      mkdir -p "$target/subagents/$name"
      ext_new_placeholder_agent "$name" > "$target/subagents/$name/agent.md"
      ext_new_placeholder_metadata "$name" > "$target/subagents/$name/metadata.json"
      ;;
    skill)
      mkdir -p "$target/skills/$name"
      ext_new_placeholder_skill "$name" > "$target/skills/$name/SKILL.md"
      ;;
    rule-pack)
      mkdir -p "$target/rules/agnostic/$name-sample"
      local rule_id
      rule_id="IN-AG-EXT-$(echo "$name" | tr '[:lower:]' '[:upper:]')-001"
      ext_new_placeholder_rule "$rule_id" "$name" > "$target/rules/agnostic/$name-sample/RULE.md"
      ;;
  esac

  echo "ok: scaffolded $type extension at $target"
  echo "  next: edit the placeholder contribution, then 'intent ext validate $name'"
}

# ---- Help ----
show_usage() {
  cat << 'EOF'
Usage: intent ext <command> [options]

Manage Intent user extensions at ~/.intent/ext/<name>/.

Commands:
  list                 List installed extensions (default)
  show <name>          Show manifest + contributions for one extension
  validate [<name>]    Validate extension manifests [Session 3]
  new <name> --type    Scaffold a new extension         [Session 4]
  help                 Show this usage

Env vars:
  INTENT_EXT_DIR       Override default ~/.intent/ext/ (used by tests)
  INTENT_EXT_DISABLE   Set to 1 to suppress ext discovery entirely

Examples:
  intent ext                        # list all extensions
  intent ext list
  intent ext show worker-bee
EOF
}

# ---- Main dispatch ----
SUBCOMMAND="${1:-list}"
shift || true

case "$SUBCOMMAND" in
  list)
    ext_list "$@"
    ;;
  show)
    ext_show "$@"
    ;;
  validate)
    ext_validate "$@"
    ;;
  new)
    ext_new "$@"
    ;;
  help|--help|-h)
    show_usage
    ;;
  *)
    echo "error: unknown ext subcommand '$SUBCOMMAND'" >&2
    echo "run 'intent ext help' for usage" >&2
    exit 1
    ;;
esac
