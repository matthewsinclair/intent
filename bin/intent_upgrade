#!/bin/bash
# intent_upgrade - convergent upgrade orchestrator (ST0043, Architecture B).
#
# Flow: detect state -> semver sanity -> verified backup -> walk an ordered
# ledger of state-probed structural steps -> single delegation to
# `intent claude upgrade --apply` (the sole canon engine) -> stamp the target
# ONCE, last (the sole stamper).
#
# Applicability of every step is decided by its on-disk state probe, never the
# top-level stamp; the stamp is written once at the end. So an interrupted run,
# re-run, performs exactly the remaining work, and no step ever writes a version
# newer than its own step. This replaces the v2.x version-case-ladder dispatcher
# (fail-forward: below-v2.9.0 sources are no longer migrated -- see ST0043).

set -e

INTENT_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INTENT_HOME="$(cd "$INTENT_BIN/.." && pwd)"
source "$INTENT_BIN/intent_helpers"
source "$INTENT_BIN/intent_migrations"

TARGET_VERSION="$(get_intent_version)"

# Ordered ledger of structural steps. Each <id> has step_<id>_needs / _run /
# _verify in bin/intent_migrations. Bash 3.2-friendly: a flat id list dispatched
# by naming convention (no declare -A).
LEDGER="relocate_config languages_field"

# Lowest source version this orchestrator migrates. Below it, fail-forward:
# refuse loudly rather than half-migrate (the below-floor ladder was pruned).
FLOOR_VERSION="2.9.0"

usage() {
  cat << EOF
Usage: intent upgrade [--backup-dir DIR] [--no-backup]

Upgrade an Intent project (v$FLOOR_VERSION+) to Intent v$TARGET_VERSION.

Options:
  --backup-dir DIR    Custom backup directory name (default: .backup/backup-TIMESTAMP)
  --no-backup         Skip backup creation (dangerous!)
  -h, --help          Show this help message

The upgrade is convergent: it probes on-disk state, runs only the structural
steps that are still needed, applies canon via 'intent claude upgrade --apply',
and stamps the target version once at the end. Safe to re-run after an
interruption -- it resumes exactly the remaining work.
EOF
  exit 0
}

# --- arg parse ------------------------------------------------------------
BACKUP_DIR=""
NO_BACKUP=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --backup-dir) BACKUP_DIR="$2"; shift 2 ;;
    --no-backup)  NO_BACKUP=true; shift ;;
    -h|--help)    usage ;;
    *)            error "Unknown option: $1" ;;
  esac
done

# --- numeric semver compare (major.minor.patch; non-digit suffix ignored) -
_vnum() { local n="${1//[!0-9]/}"; echo "$((10#${n:-0}))"; }
version_gt() {
  local a1 a2 a3 b1 b2 b3
  IFS=. read -r a1 a2 a3 <<< "$1"
  IFS=. read -r b1 b2 b3 <<< "$2"
  a1=$(_vnum "$a1"); a2=$(_vnum "$a2"); a3=$(_vnum "$a3")
  b1=$(_vnum "$b1"); b2=$(_vnum "$b2"); b3=$(_vnum "$b3")
  if [ "$a1" -ne "$b1" ]; then [ "$a1" -gt "$b1" ]; return; fi
  if [ "$a2" -ne "$b2" ]; then [ "$a2" -gt "$b2" ]; return; fi
  [ "$a3" -gt "$b3" ]
}

_any_step_needs() {
  local step
  for step in $LEDGER; do
    if "step_${step}_needs" .; then return 0; fi
  done
  return 1
}

# --- 1. detect state + semver sanity (BEFORE any mutation) ----------------
VERSION="$(detect_project_version . || echo "")"
[ -n "$VERSION" ] || error "could not detect a project version (not an Intent project, or an unrecognised layout). For a new project: intent init"
case "$VERSION" in
  [0-9]*.[0-9]*) : ;;
  *) error "unrecognised project version '$VERSION'; cannot upgrade safely" ;;
esac

# Refuse a downgrade before touching anything.
if version_gt "$VERSION" "$TARGET_VERSION"; then
  error "refusing downgrade: project is at v$VERSION, target is v$TARGET_VERSION"
fi

# Fail-forward floor: below-v2.9.0 layouts are no longer migrated.
if version_gt "$FLOOR_VERSION" "$VERSION"; then
  error "unsupported source version v$VERSION: the upgrade floor is v$FLOOR_VERSION (older STP/Intent layouts are no longer migrated; see intent/history). Re-create the project with 'intent init' or migrate manually."
fi

echo "Current version: $VERSION"
echo "Target version:  $TARGET_VERSION"

# Already fully converged? (at target stamp AND no structural step pending)
if [ "$VERSION" = "$TARGET_VERSION" ] && ! _any_step_needs; then
  echo "ok: already at intent v$TARGET_VERSION"
  exit 0
fi

echo "upgrading: $VERSION -> $TARGET_VERSION"

# --- 2. verified backup (first point any mutation could occur) ------------
if [ "$NO_BACKUP" != true ]; then
  if [ -z "$BACKUP_DIR" ]; then
    BACKUP_NAME="backup-$(date +%Y%m%d-%H%M%S)"
  else
    BACKUP_NAME=$(basename "$BACKUP_DIR")
  fi
  BACKUP_DIR=".backup/$BACKUP_NAME"
  echo "Creating backup in $BACKUP_DIR..."
  mkdir -p "$BACKUP_DIR" || error "cannot create backup dir $BACKUP_DIR; aborting upgrade (nothing has been migrated)"
  # A failed copy aborts before any migration mutates the project -- never report
  # a backup that does not exist (ST0042 T3).
  for item in .intent intent CLAUDE.md; do
    if [ -e "$item" ]; then
      cp -r "$item" "$BACKUP_DIR/" \
        || error "Backup of $item to $BACKUP_DIR failed; aborting upgrade (nothing has been migrated)"
    fi
  done
  echo "Backup created successfully"
fi

echo ""
echo "Walking the upgrade ledger..."

# --- 3. walk the ordered ledger of state-probed steps ---------------------
for step in $LEDGER; do
  if "step_${step}_needs" .; then
    echo "step: $step"
    "step_${step}_run" . || error "upgrade step '$step' failed; nothing stamped (re-run to resume the remaining work)"
    "step_${step}_verify" . || error "upgrade step '$step' postcondition not met; nothing stamped (re-run to resume)"
  else
    echo "step: $step (already satisfied)"
  fi
done

# --- 4. single delegation: canon convergence (the sole canon engine) ------
echo ""
echo "Applying canon (intent claude upgrade --apply)..."
"$INTENT_BIN/intent" claude upgrade --project-dir . --apply >&2 \
  || error "canon apply failed; nothing stamped (re-run to resume)"

# Propagate skill + subagent updates to any already-installed ~/.claude mirror.
# Failure-tolerant (a missing mirror or a user 'N' at a prompt must not break the
# upgrade) and no --force, so user customisations are never silently lost.
if [ -d "$INTENT_HOME/intent/plugins/claude/skills/in-whiteboard" ]; then
  echo "Ensuring in-whiteboard skill is installed..."
  "$INTENT_BIN/intent" claude skills install in-whiteboard || true
  echo "Syncing canon skill updates..."
  "$INTENT_BIN/intent" claude skills sync || true
fi
echo "Syncing canon subagent updates..."
"$INTENT_BIN/intent" claude subagents sync || true

# --- 5. stamp the target ONCE, last (the sole stamper) --------------------
CONFIG="intent/.config/config.json"
if [ -f "$CONFIG" ] && command -v jq >/dev/null 2>&1; then
  current="$(jq -r '.intent_version // ""' "$CONFIG")"
  if [ "$current" = "$TARGET_VERSION" ]; then
    echo "stamp: already at v$TARGET_VERSION"
  else
    tmp="$(mktemp)"
    jq --arg v "$TARGET_VERSION" '.intent_version = $v | del(.version)' "$CONFIG" > "$tmp"
    mv "$tmp" "$CONFIG"
    echo "stamped: intent_version = $TARGET_VERSION"
  fi
else
  error "cannot stamp the target: $CONFIG is missing after the ledger (upgrade incomplete)"
fi

echo ""
echo "ok: upgraded $VERSION -> $TARGET_VERSION"
if [ "$NO_BACKUP" != true ]; then
  echo "Backup location: $BACKUP_DIR"
fi
echo ""
echo "Next steps:"
echo "1. Run 'intent doctor' to verify configuration"
echo "2. Review the canon files refreshed by 'intent claude upgrade'"
