#!/bin/bash
# intent_helpers - Shared functions for Intent migration and utilities

# ---- Core Shared Helpers ----

# Display an error message and exit
error() {
  echo "Error: $1" >&2
  exit 1
}
export -f error

# Display a warning to stderr (non-fatal).
warning() {
  echo "Warning: $1" >&2
}
export -f warning

# Print informational output to stdout. Honours the optional QUIET env var
# so callers that respect --quiet can rely on this helper directly.
info() {
  [ "${QUIET:-}" = true ] && return 0
  echo "$@"
}
export -f info

# Get Intent version from VERSION file.
# This is THE fallback site (Highlander, ST0042/WP-05): the function never
# fails, so callers use plain $(get_intent_version) -- no per-site
# `|| echo "X.Y.Z"` decorations. A missing VERSION file means a broken
# install; surface it rather than silently picking a stale literal.
get_intent_version() {
  local version_file="${INTENT_HOME:-$(dirname "${BASH_SOURCE[0]}")/..}/VERSION"

  if [ -f "$version_file" ]; then
    cat "$version_file"
  else
    warning "VERSION file not found at $version_file; install may be broken"
    echo "2.2.1"
  fi
}
export -f get_intent_version

# Calculate SHA256 checksum for a file
calculate_checksum() {
  local file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" | cut -d' ' -f1
  else
    echo "unknown"
  fi
}
export -f calculate_checksum

# Get terminal width with fallback chain
get_terminal_width() {
  local width="${COLUMNS:-}"
  # Subshell isolates the < /dev/tty redirection -- when the calling shell has
  # no controlling TTY, bash emits "Device not configured" on its own stderr
  # before stty runs; the outer 2>/dev/null inside the subshell captures it.
  [ -z "$width" ] && width=$( (stty size < /dev/tty) 2>/dev/null | cut -d' ' -f2)
  [ -z "$width" ] && width=$(tput cols 2>/dev/null)
  [ -z "$width" ] && width=100
  echo "$width"
}
export -f get_terminal_width

# Read a single string field from a JSON config file.
# Values are assigned by the caller verbatim -- never evaled -- so shell
# metacharacters in config values are inert (ST0042 T1). This is THE config
# field reader (Highlander, ST0042/WP-05); get_config_field below wraps it
# for the common project-local-config-with-default case.
read_config_field() {
  local file=$1
  local field=$2

  if [ ! -f "$file" ]; then
    return 1
  fi

  require_jq || exit 1

  jq -r --arg key "$field" '.[$key] // empty' "$file" 2>/dev/null
}
export -f read_config_field

# Extract a field from the project-local intent/.config/config.json with a
# default. Thin wrapper over read_config_field.
get_config_field() {
  local field="$1"
  local default="${2:-}"
  local val
  val="$(read_config_field intent/.config/config.json "$field" 2>/dev/null)"
  if [ -n "$val" ]; then
    echo "$val"
  else
    echo "$default"
  fi
}
export -f get_config_field

# Default width for GENERATED FILES: the project config's `dft_width`, or 120.
# A file is read anywhere, so it takes a stable, generous default rather than
# the width of whatever terminal happened to run the command.
#
# NOTE (2026-07-07): the `st`/`wp` list tables no longer consume this -- they are
# content-fit via render_table (below), which superseded ST0051's dft_width path.
# get_default_width therefore has no in-tree caller today, but `dft_width` is a
# public, `intent init`-seeded config knob for other generated content. DELIBERATELY
# RETAINED (matts) -- do NOT remove as "dead code".
get_default_width() {
  get_config_field dft_width 120
}
export -f get_default_width

# Render a table to stdout, filling a target width. $1 is the pipe-delimited
# header row (eg "ID|Slug|Status"); data rows are read from stdin, one per line,
# pipe-delimited with the same column count. $2 is the width to fill (the
# terminal width): columns start content-fit (each sized to its widest cell) and
# then grow to fill $2, so nothing is truncated and the table uses the full
# width. $2 = 0 or absent renders content-fit only. THE list-table renderer
# (Highlander): `intent st list` and `intent wp list` both render through this,
# so their column layout cannot drift apart.
render_table() {
  local header_line="$1"
  local target_width="${2:-0}"   # fill this width (the terminal); 0 = content-fit only
  local -a headers=() rows=() widths=() cells=()
  local line i clen ncols dashes fmt seprow

  # `IFS='|' read` scopes IFS to the read command only -- no global save/restore,
  # so the caller's IFS (which may be unset) can't leak in and break the
  # word-splitting-free logic below.
  IFS='|' read -r -a headers <<< "$header_line"
  ncols=${#headers[@]}

  # Slurp the data rows from stdin.
  while IFS= read -r line; do
    rows+=("$line")
  done

  # Content-fit widths: seed from the header labels, expand to the widest cell.
  i=0
  while [ "$i" -lt "$ncols" ]; do
    widths[i]=${#headers[i]}
    i=$((i + 1))
  done
  if [ ${#rows[@]} -gt 0 ]; then
    for line in "${rows[@]}"; do
      IFS='|' read -r -a cells <<< "$line"
      i=0
      while [ "$i" -lt "$ncols" ]; do
        clen=${#cells[i]}
        if [ "$clen" -gt "${widths[i]}" ]; then widths[i]=$clen; fi
        i=$((i + 1))
      done
    done
  fi

  # Expand columns to fill target_width (the terminal width) when the content-fit
  # table is narrower -- so the table uses the full terminal like a normal CLI
  # table, and `st list` / `st sync` / `wp list` all fill it identically. The
  # slack is shared out in proportion to each column's content width (the text
  # column, being widest, absorbs most); the remainder lands on the last column.
  # Content-fit is the floor, so nothing is ever truncated.
  if [ "$target_width" -gt 0 ] && [ "$ncols" -gt 0 ]; then
    local sep_total content_total table_total slack distributed add
    sep_total=$(( (ncols - 1) * 3 ))
    content_total=0
    i=0
    while [ "$i" -lt "$ncols" ]; do content_total=$(( content_total + widths[i] )); i=$((i + 1)); done
    table_total=$(( content_total + sep_total ))
    if [ "$table_total" -lt "$target_width" ] && [ "$content_total" -gt 0 ]; then
      slack=$(( target_width - table_total ))
      distributed=0
      i=0
      while [ "$i" -lt "$ncols" ]; do
        if [ "$i" -eq "$(( ncols - 1 ))" ]; then
          add=$(( slack - distributed ))
        else
          add=$(( slack * widths[i] / content_total ))
        fi
        widths[i]=$(( widths[i] + add ))
        distributed=$(( distributed + add ))
        i=$((i + 1))
      done
    fi
  fi

  # Build the row format ("%-w1s | %-w2s | ...") and the separator ("---|---").
  # Dashes come from `printf -v` + substitution, not `seq` word-splitting, so
  # they are independent of the caller's IFS.
  fmt=""
  seprow=""
  i=0
  while [ "$i" -lt "$ncols" ]; do
    printf -v dashes '%*s' "${widths[i]}" ''
    dashes="${dashes// /-}"
    if [ "$i" -eq 0 ]; then
      fmt="%-${widths[i]}s"
      seprow="$dashes"
    else
      fmt="$fmt | %-${widths[i]}s"
      seprow="$seprow-|-$dashes"
    fi
    i=$((i + 1))
  done
  fmt="$fmt\n"

  # Header, separator, then the data rows -- all through the one format.
  printf "$fmt" "${headers[@]}"
  printf '%s\n' "$seprow"
  if [ ${#rows[@]} -gt 0 ]; then
    for line in "${rows[@]}"; do
      IFS='|' read -r -a cells <<< "$line"
      printf "$fmt" "${cells[@]}"
    done
  fi
}
export -f render_table

# Find project root by looking for intent/stp markers. THE project-root
# resolver (Highlander, ST0042/WP-05) -- walks up from the caller's cwd.
find_project_root() {
  local current_dir=$(pwd)

  while [ "$current_dir" != "/" ]; do
    # Check for v2.0.0 structure
    if [ -f "$current_dir/intent/.config/config.json" ]; then
      echo "$current_dir"
      return 0
    fi

    # Check for legacy structures
    if [ -d "$current_dir/stp/.config" ] || [ -f "$current_dir/.stp-config" ]; then
      echo "$current_dir"
      return 0
    fi

    # Check for directory-based or file-based steel threads
    if [ -d "$current_dir/stp/prj/st" ]; then
      echo "$current_dir"
      return 0
    fi

    current_dir=$(dirname "$current_dir")
  done

  # No project root found
  return 1
}
export -f find_project_root

# Locate a steel-thread directory across the status subdirectories.
# THE ST-dir resolver (Highlander, ST0042/WP-05). Echoes the directory,
# returns 1 if the thread is not found anywhere.
resolve_st_dir() {
  local st_id="$1"
  local base_dir="${2:-intent/st}"
  local location

  for location in \
    "$base_dir/$st_id" \
    "$base_dir/COMPLETED/$st_id" \
    "$base_dir/NOT-STARTED/$st_id" \
    "$base_dir/CANCELLED/$st_id"; do
    if [ -d "$location" ]; then
      echo "$location"
      return 0
    fi
  done

  return 1
}
export -f resolve_st_dir

# ---- Extension root resolution ----
# THE ext-root resolver pair (Highlander, ST0042/WP-05). Honours
# INTENT_EXT_DIR (used by tests) and INTENT_EXT_DISABLE=1 (escape hatch:
# resolves to empty, so every consumer skips ext discovery).
ext_root_dir() {
  if [ "${INTENT_EXT_DISABLE:-}" = "1" ]; then
    echo ""
    return 0
  fi
  echo "${INTENT_EXT_DIR:-$HOME/.intent/ext}"
}
export -f ext_root_dir

# Enumerate extension directory names under the ext root (dotfiles and _*
# excluded). Output one name per line.
ext_enumerate_names() {
  local root
  root="$(ext_root_dir)"
  [ -z "$root" ] && return 0
  [ -d "$root" ] || return 0

  local ext_dir name
  for ext_dir in "$root"/*/; do
    [ -d "$ext_dir" ] || continue
    name="$(basename "$ext_dir")"
    case "$name" in
      .*|_*) continue ;;
    esac
    echo "$name"
  done
}
export -f ext_enumerate_names

# Get all languages declared in the project config, one per line.
# Returns 0 lines (and 0 exit) when languages is empty, absent, or config
# unreadable. Reads via jq if available; falls back silently otherwise.
# (Pre-commit hook and SKILL.md prose rely on this being the single source.)
get_project_languages() {
  local config="${1:-intent/.config/config.json}"
  [ -f "$config" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  jq -r '(.languages // []) | .[]' "$config" 2>/dev/null || true
}
export -f get_project_languages

# Append a language to the project's languages array if not already present.
# Idempotent. Writes config atomically via temp file + mv.
add_project_language() {
  local lang="$1"
  local config="${2:-intent/.config/config.json}"
  [ -f "$config" ] || return 1
  require_jq >/dev/null 2>&1 || return 1
  local tmp
  tmp=$(mktemp)
  jq --arg lang "$lang" '
    if (.languages // []) | index($lang) then
      .
    else
      .languages = ((.languages // []) + [$lang])
    end
  ' "$config" > "$tmp"
  mv "$tmp" "$config"
}
export -f add_project_language

# Remove a language from the project's languages array if present.
# Idempotent. Writes config atomically via temp file + mv.
remove_project_language() {
  local lang="$1"
  local config="${2:-intent/.config/config.json}"
  [ -f "$config" ] || return 1
  require_jq >/dev/null 2>&1 || return 1
  local tmp
  tmp=$(mktemp)
  jq --arg lang "$lang" '.languages = ((.languages // []) - [$lang])' "$config" > "$tmp"
  mv "$tmp" "$config"
}
export -f remove_project_language

# Require jq to be installed (returns 1 with instructions if not)
require_jq() {
  if command -v jq >/dev/null 2>&1; then
    return 0
  fi
  echo "Error: jq is required but not installed." >&2
  echo "" >&2
  echo "Intent requires jq for JSON configuration parsing." >&2
  echo "" >&2
  echo "Installation instructions:" >&2
  if [ "$(uname)" = "Darwin" ]; then
    echo "  macOS: brew install jq" >&2
  elif [ "$(uname)" = "Linux" ]; then
    echo "  Debian/Ubuntu: sudo apt-get install jq" >&2
    echo "  RedHat/CentOS: sudo yum install jq" >&2
    echo "  Arch Linux: sudo pacman -S jq" >&2
  else
    echo "  Please install jq using your system's package manager" >&2
  fi
  echo "" >&2
  echo "For more information: https://stedolan.github.io/jq/download/" >&2
  return 1
}
export -f require_jq

# Require Claude Code to be installed
require_claude() {
  if [ -d "$HOME/.claude" ]; then
    return 0
  fi
  echo "Error: Claude Code not detected. Please install Claude Code first." >&2
  echo "Visit: https://claude.ai/download" >&2
  return 1
}
export -f require_claude

# Require a project root to be set (caller must load config first)
require_project_root() {
  if [ -n "${PROJECT_ROOT:-}" ]; then
    return 0
  fi
  echo "Error: Not in an Intent project directory" >&2
  echo "Run 'intent init' to create a new project first" >&2
  return 1
}
export -f require_project_root

# Normalise a steel thread ID (bare number or partial -> ST####)
normalise_st_id() {
  local id="$1"
  # 10# forces base-10 so a leading-zero id (eg 0044) is not read as octal by
  # printf %d under /bin/bash 3.2 (0044 -> 36 -> ST0036, the wrong thread).
  if [[ "$id" =~ ^[0-9]+$ ]]; then
    printf "ST%04d" "$((10#$id))"
  elif [[ "$id" =~ ^ST[0-9]+$ ]]; then
    # ST-prefixed short id (eg ST44) canonicalises to the padded form.
    printf "ST%04d" "$((10#${id#ST}))"
  elif [[ ! "$id" =~ ^ST ]]; then
    echo "ST$id"
  else
    echo "$id"
  fi
}
export -f normalise_st_id

# Parse a WP specifier (STID/NN or bare STID) into globals ST_ID and WP_NUM.
# THE specifier parser (Highlander) -- reused by intent_wp and intent_todo
# (moved here from intent_wp for ST0050). $2 = require_wp (default true):
# error when the /NN part is absent.
# shellcheck disable=SC2034  # ST_ID / WP_NUM are outputs consumed by callers
parse_wp_specifier() {
  local spec="$1"
  local require_wp="${2:-true}"

  if [[ "$spec" == */* ]]; then
    local st_part="${spec%/*}"
    local wp_part="${spec##*/}"
    ST_ID=$(normalise_st_id "$st_part")
    WP_NUM=$(printf "%02d" "$((10#$wp_part))")
  else
    ST_ID=$(normalise_st_id "$spec")
    WP_NUM=""
    if [ "$require_wp" = "true" ]; then
      error "Work package number is required (e.g., $ST_ID/01)"
    fi
  fi
}
export -f parse_wp_specifier

# Escape special characters for sed replacement strings
escape_sed_replacement() {
  local s="$1"
  s="${s//\\/\\\\}"   # \ -> \\  (must be first)
  s="${s//\//\\/}"     # / -> \/
  s="${s//&/\\&}"      # & -> \&
  echo "$s"
}
export -f escape_sed_replacement

# Detect current STP/Intent version
detect_project_version() {
  local project_root=${1:-.}

  # Check for v2.10.0+ (Intent post-relocation layout: intent/.config/)
  if [ -f "$project_root/intent/.config/config.json" ]; then
    # Try intent_version first, then version field
    local version=$(jq -r '.intent_version // .version // empty' "$project_root/intent/.config/config.json" 2>/dev/null)
    if [ -n "$version" ]; then
      echo "$version"
      return 0
    fi
  fi

  # Check for v2.0.0 - v2.9.x (Intent pre-relocation layout: .intent/).
  # This branch is the narrow exception to ST0036's fail-forward posture:
  # detect_project_version must recognise the legacy layout so that
  # `intent upgrade` can chain through migrate_v2_9_0_to_v2_10_0 and
  # relocate the directory. find_project_root and load_intent_config
  # remain v2.10.0-only.
  if [ -f "$project_root/.intent/config.json" ]; then
    local version=$(jq -r '.intent_version // .version // empty' "$project_root/.intent/config.json" 2>/dev/null)
    if [ -n "$version" ]; then
      echo "$version"
      return 0
    fi
  fi

  # Check for v1.2.0+ (version file)
  if [ -f "$project_root/stp/.config/version" ]; then
    local version=$(grep "^stp_version:" "$project_root/stp/.config/version" | sed 's/stp_version:[[:space:]]*//')
    if [ -n "$version" ]; then
      echo "$version"
      return 0
    fi
  fi
  
  # Check for v0.0.0 (.stp-config)
  if [ -f "$project_root/.stp-config" ]; then
    echo "0.0.0"
    return 0
  fi
  
  # Check for directory structure patterns
  if [ -d "$project_root/stp/prj/st" ]; then
    # Has STP structure but no version - assume 1.0.0
    echo "1.0.0"
    return 0
  fi
  
  # Unable to determine version
  return 1
}
# Alias for compatibility
detect_stp_version() {
  detect_project_version "$@"
}
