# Check if project needs v2.3.2 upgrade
needs_v2_3_2_upgrade() {
  local version=$1

  case "$version" in
    "2.0.0"|"2.1.0"|"2.2.0"|"2.2.1"|"2.3.0"|"2.3.1")
      return 0  # Needs 2.3.2 upgrade
      ;;
    *)
      return 1  # Already upgraded or different version
      ;;
  esac
}

