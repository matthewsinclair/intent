# needs_v2_9_0_upgrade VERSION
# Returns 0 if VERSION is older than 2.9.0 (and therefore needs the v2.9.0 migration step).
# Returns 1 for 2.9.0 and forward (the 2.9.0 step itself has already run).
needs_v2_9_0_upgrade() {
  local version=$1

  case "$version" in
    "2.9.0"|"2.9."*|"2.10."*|"3."*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

# needs_v2_10_0_upgrade VERSION [PROJECT_ROOT]
# Returns 0 if the v2.10.0 migration is needed for this project.
#
# The v2.10.0 migration has TWO concerns: stamp bump and directory relocation
# (.intent/ -> intent/.config/ per ST0036). A project may be at the target
# stamp but still on the pre-relocation layout -- e.g. Intent itself, which
# was retargeted from v2.9.1 to v2.10.0 mid-ST0035 before ST0036 implementation
# began. The dispatcher must invoke migrate_v2_9_0_to_v2_10_0 in that case so
# intent_relocate_dotintent gets a chance to run.
#
# Layout shortcut (ST0036/WP01 fix surfaced by WP08): if the project still has
# .intent/ and no intent/.config/, return 0 (needs upgrade) regardless of stamp.
# Otherwise: standard chronological version comparison.
#
# Returns 1 for 2.10.0+ AND already-relocated layout.
# Note: v2.9.1 through v2.9.9 were never released; the jump is v2.9.0 -> v2.10.0
# (LLM canon + directory relocation bundled together as one breaking release).
needs_v2_10_0_upgrade() {
  local version=$1
  local project_root=${2:-.}

  # Layout shortcut: stamp may be 2.10.0+ but layout still .intent/.
  if [ -d "$project_root/.intent" ] && [ ! -d "$project_root/intent/.config" ]; then
    return 0
  fi

  case "$version" in
    "2.10."*|"2.11."*|"2.12."*|"2.13."*|"2.14."*|"2.15."*|"2.16."*|"2.17."*|"2.18."*|"2.19."*|"3."*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

# generate_ext_readme TARGET_PATH
# Writes the README that ships with a freshly bootstrapped ~/.intent/ext/.
# Pure file emission; safe to call repeatedly.
generate_ext_readme() {
  local target=$1

  cat > "$target" << 'EOF'
# Intent User Extensions

This directory holds user-local Intent extensions: skills, subagents, and rule
packs that you install without forking the Intent repo. Anything you drop under
`~/.intent/ext/<name>/` (with a valid `extension.json`) is discovered the next
time `intent` runs.

## Listing extensions

    intent ext list

## Inspecting an extension

    intent ext show <name>

## Validating an extension

    intent ext validate <name>

## Creating an extension

    intent ext new <name> --subagent     # scaffold a subagent
    intent ext new <name> --skill        # scaffold a skill
    intent ext new <name> --rule-pack    # scaffold a rule pack

## Reference example

`worker-bee/` (seeded here on Intent v2.9.0 upgrade if absent) is the worked
example. See `intent/docs/writing-extensions.md` in the Intent repo for the
end-to-end walkthrough.
EOF
}

# Migrate v2.8.2 to v2.9.0 - extension system + critic subagent family
#
# Fail-forward migration:
#   1. Stamp .intent/config.json:intent_version to 2.9.0
#   2. Bootstrap ~/.intent/ext/ (user-global, one-shot) with README
#   3. Seed ~/.intent/ext/worker-bee/ from lib/templates/ext-seeds/worker-bee
#      (skip if already present so user customisation survives)
#   4. Prune installed copies of subagents removed from canon (elixir, worker-bee)
#      and remove their entries from ~/.intent/agents/installed-agents.json
#
# Idempotent: a second run is a no-op (presence checks at every step).
migrate_v2_8_2_to_v2_9_0() {
  local project_root=$1

  echo "Upgrading to Intent v2.9.0 (extension system, critic subagent family)..."

  # 1. Version stamp
  if [ -f "$project_root/.intent/config.json" ]; then
    local temp_file
    temp_file=$(mktemp)
    jq --arg v "2.9.0" '.intent_version = $v | del(.version)' "$project_root/.intent/config.json" > "$temp_file"
    mv "$temp_file" "$project_root/.intent/config.json"
    echo "  stamped: intent_version = 2.9.0"
  fi

  # 2. Bootstrap ~/.intent/ext/ (user-global; one-time effect)
  local ext_dir="$HOME/.intent/ext"
  if [ ! -d "$ext_dir" ]; then
    mkdir -p "$ext_dir"
    generate_ext_readme "$ext_dir/README.md"
    echo "  bootstrapped: $ext_dir"
  fi

  # 3. Seed worker-bee ext (only if not already present)
  local wb_ext="$ext_dir/worker-bee"
  local wb_seed="$INTENT_HOME/lib/templates/ext-seeds/worker-bee"
  if [ ! -d "$wb_ext" ] && [ -d "$wb_seed" ]; then
    cp -r "$wb_seed" "$wb_ext"
    echo "  seeded: ~/.intent/ext/worker-bee (from canon ext-seeds)"
  elif [ -d "$wb_ext" ]; then
    echo "  skipped: ~/.intent/ext/worker-bee (already present, not overwriting)"
  fi

  # 4. Prune installed copies of removed subagents
  local agent installed manifest temp_file
  for agent in elixir worker-bee; do
    installed="$HOME/.claude/agents/${agent}.md"
    if [ -f "$installed" ]; then
      rm "$installed"
      echo "  pruned: ~/.claude/agents/${agent}.md"
    fi
    manifest="$HOME/.intent/agents/installed-agents.json"
    if [ -f "$manifest" ]; then
      temp_file=$(mktemp)
      jq --arg name "$agent" '(.installed) |= map(select(.name != $name))' "$manifest" > "$temp_file" \
        && mv "$temp_file" "$manifest"
    fi
  done

  echo "  Migration to v2.9.0 complete!"
  echo ""
  echo "  IMPORTANT CHANGES IN v2.9.0:"
  echo "    - NEW: ~/.intent/ext/ extension system for user skills/subagents/rules"
  echo "    - NEW: critic-{elixir,rust,swift,lua,shell} subagents (rule-library enforcers)"
  echo "    - REMOVED: elixir subagent (content split into rule library + critic-elixir)"
  echo "    - RELOCATED: worker-bee now seeded at ~/.intent/ext/worker-bee/"
  echo "    - Installed copies of elixir and worker-bee have been pruned."
  echo "    - To reinstall worker-bee from the seed: intent ext show worker-bee"
}

# Relocate .intent/ -> intent/.config/ atomically (ST0036/WP01).
#
# Behaviour:
#   - Recovery probe: refuse if a previous interrupted migration left a sentinel.
#   - Idempotence shortcut: if intent/.config/ exists and .intent/ does not, no-op.
#   - Conflict refusal: refuse if both .intent/ and intent/.config/ exist.
#   - Symlink refusal: refuse to relocate a symlinked .intent/.
#   - Atomic move: mv .intent intent/.config (with cp -a + checksum + rm fallback
#     for cross-filesystem cases).
#   - Sentinel: written inside .intent/ before the mv (so it travels with the
#     directory); removed from intent/.config/ after the move succeeds.
#
# Returns:
#   0 on success or no-op
#   1 on user-action-required refusals (interrupted/conflict/symlink)
#   2 on unrecoverable errors (mkdir/touch/cp/checksum failed; sentinel preserved)
intent_relocate_dotintent() {
  local project_root=$1
  local dotintent="$project_root/.intent"
  local config_dir="$project_root/intent/.config"
  local sentinel="$config_dir/.migration-in-progress"
  local recovery_url="intent/docs/migration-v2.10.0.md#recovery-from-interrupted-migration"

  # Recovery probe: prior interrupted migration?
  if [ -f "$sentinel" ]; then
    echo "Error: interrupted migration detected at $sentinel" >&2
    echo "  See $recovery_url for recovery steps." >&2
    return 1
  fi

  # Idempotence shortcut: already relocated?
  if [ -d "$config_dir" ] && [ ! -e "$dotintent" ]; then
    echo "  layout: intent/.config already in place (no relocation needed)"
    return 0
  fi

  # Conflict refusal: both exist?
  if [ -e "$dotintent" ] && [ -d "$config_dir" ]; then
    echo "Error: both .intent/ and intent/.config/ exist; manual intervention required" >&2
    echo "  See $recovery_url for guidance." >&2
    return 1
  fi

  # Symlink refusal: .intent is a symlink?
  if [ -L "$dotintent" ]; then
    echo "Error: .intent is a symbolic link; refusing to relocate symlinked layouts" >&2
    echo "  See $recovery_url for guidance." >&2
    return 1
  fi

  # Nothing to do? (no .intent/ at all -- fresh project or already migrated by other means)
  if [ ! -e "$dotintent" ]; then
    echo "  layout: no .intent/ found (skipping relocation)"
    return 0
  fi

  # Parent create (handles fresh-from-v2.0.0 layouts; harmless if intent/ exists)
  mkdir -p "$project_root/intent" || {
    echo "Error: cannot create $project_root/intent (read-only filesystem?)" >&2
    return 2
  }

  # Sentinel write inside .intent/ -- travels with the mv into intent/.config/
  touch "$dotintent/.migration-in-progress" || {
    echo "Error: cannot write sentinel inside .intent/ (read-only filesystem?)" >&2
    return 2
  }

  # Atomic move (with cross-filesystem fallback)
  if mv "$dotintent" "$config_dir" 2>/dev/null; then
    echo "  relocated: .intent/ -> intent/.config/"
  else
    echo "  fallback: copying .intent/ -> intent/.config/ (cross-filesystem move)"
    if ! cp -a "$dotintent" "$config_dir"; then
      echo "Error: cp -a fallback failed; .intent/ preserved at $dotintent" >&2
      echo "  Sentinel at $dotintent/.migration-in-progress; resolve and re-run." >&2
      return 2
    fi
    local src_sum dst_sum
    src_sum=$(cd "$dotintent" 2>/dev/null && find . -type f -not -name '.migration-in-progress' | sort | xargs shasum 2>/dev/null | shasum | awk '{print $1}')
    dst_sum=$(cd "$config_dir" 2>/dev/null && find . -type f -not -name '.migration-in-progress' | sort | xargs shasum 2>/dev/null | shasum | awk '{print $1}')
    if [ "$src_sum" != "$dst_sum" ]; then
      echo "Error: checksum mismatch after copy; .intent/ preserved for inspection" >&2
      rm -rf "$config_dir"
      return 2
    fi
    rm -rf "$dotintent"
    echo "  relocated: .intent/ -> intent/.config/ (via copy fallback)"
  fi

  # Sentinel removal (now at intent/.config/.migration-in-progress post-mv)
  rm -f "$sentinel" || {
    echo "Warning: could not remove sentinel at $sentinel" >&2
    echo "  Migration is complete; delete sentinel manually." >&2
  }

  return 0
}

# Migrate v2.9.0 to v2.10.0 - canonical LLM config + directory relocation (ST0035 + ST0036)
#
# Two bundled concerns, executed in order:
# 1. ST0036 directory relocation (.intent/ -> intent/.config/) -- delegated to
#    intent_relocate_dotintent above. Atomic mv + sentinel + cross-FS fallback.
# 2. Version stamp at the post-relocation path (intent/.config/config.json).
# 3. ST0035 canon-apply (session hooks, pre-commit critic gate, refreshed root
#    AGENTS.md + CLAUDE.md + usage-rules.md, deletion of intent/llm/AGENTS.md) --
#    shipped via intent_claude_upgrade and invoked here with --apply.
#
# Idempotent: layout-state shortcut in intent_relocate_dotintent + stamp
# comparison guard mean a re-run on a v2.10.0 project is a no-op for both phases.
# Importantly, idempotence is keyed on layout state (intent/.config/ exists?), NOT
# stamp value -- a project may be stamped 2.10.0 but still on the .intent/ layout
# (e.g. Intent itself, which was retargeted to 2.10.0 mid-ST0035 before ST0036
# implementation began). Layout-keyed idempotence handles that case correctly.
migrate_v2_9_0_to_v2_10_0() {
  local project_root=$1

  echo "Upgrading to Intent v2.10.0 (canonical LLM config + directory relocation; see ST0035 + ST0036)..."

  # Phase 1: directory relocation (.intent/ -> intent/.config/) per ST0036/WP01.
  intent_relocate_dotintent "$project_root" || return $?

  # Phase 2: version stamp at the post-relocation path.
  if [ -f "$project_root/intent/.config/config.json" ]; then
    local current
    current=$(jq -r '.intent_version // ""' "$project_root/intent/.config/config.json")
    if [ "$current" = "2.10.0" ]; then
      echo "  stamp: already at v2.10.0"
    else
      local temp_file
      temp_file=$(mktemp)
      jq --arg v "2.10.0" '.intent_version = $v | del(.version)' "$project_root/intent/.config/config.json" > "$temp_file"
      mv "$temp_file" "$project_root/intent/.config/config.json"
      echo "  stamped: intent_version = 2.10.0"
    fi
  fi

  # Phase 3: canon apply (ST0035/WP-11). Installs .claude/settings.json + hook
  # scripts, .git/hooks/pre-commit, .intent_critic.yml, root CLAUDE.md,
  # usage-rules.md; plants intent/llm/MODULES.md + DECISION_TREE.md if missing;
  # deletes any legacy intent/llm/AGENTS.md. Idempotent.
  if command -v intent >/dev/null 2>&1; then
    echo "  Applying v2.10.0 canon (intent claude upgrade --apply)..."
    if ! intent claude upgrade --project-dir "$project_root" --apply >&2; then
      echo "  warning: canon apply reported a non-zero exit; review output and re-run." >&2
    fi
  else
    echo "  warning: 'intent' CLI not on PATH; skipping canon apply." >&2
    echo "  run 'intent claude upgrade --apply' manually once Intent is installed." >&2
  fi

  echo "  Migration to v2.10.0 complete."
}

# Migrate v2.2.0 to v2.2.1
migrate_v2_2_to_v2_2_1() {
  local project_root=$1
  
  local target_version="$(get_intent_version 2>/dev/null || echo "2.2.1")"
  echo "Upgrading v2.2.0 to v$target_version..."
  
  # Update .intent/config.json to target version
  if [ -f "$project_root/.intent/config.json" ]; then
    echo "  Updating project version to $target_version..."
    local temp_file=$(mktemp)
    jq --arg v "$target_version" '.intent_version = $v | del(.version)' "$project_root/.intent/config.json" > "$temp_file"
    mv "$temp_file" "$project_root/.intent/config.json"
  fi
  
  echo "  Version updated to $target_version"
}

# Generate basic AGENTS.md at project root as fallback (no generator available).
# Canonical location since v2.10.0 (see ST0035/WP08).
_generate_basic_agents_md() {
  local project_root=$1
  cat > "$project_root/AGENTS.md" << 'EOF'
# AGENTS.md

## Project Overview
This is an Intent project. See CLAUDE.md for project-specific guidelines.

## Development Environment
### Prerequisites
- Bash 4.0 or higher
- POSIX-compliant shell environment

## Build and Test Commands
### Testing
```bash
# Check for test scripts in your project
intent doctor
```

## Code Style Guidelines
- Follow existing patterns in the codebase
- See CLAUDE.md for project-specific guidelines

## Intent-Specific Information
### Steel Thread Process
Work is organized into steel threads (ST####) under intent/st/

### Available Commands
- `intent st list` - List all steel threads
- `intent agents sync` - Update this AGENTS.md
- `intent claude subagents list` - List Claude subagents
EOF
  echo "    Generated basic AGENTS.md template"
}

# Migrate v2.2.x to v2.3.0 - Plugin architecture and AGENTS.md support
migrate_v2_2_to_v2_3_0() {
  local project_root=$1
  
  local target_version="$(get_intent_version 2>/dev/null || echo "2.3.0")"
  echo "Upgrading to Intent v$target_version with plugin architecture..."
  
  # 1. Create plugin directory structure
  echo "  Creating plugin architecture..."
  mkdir -p "$project_root/intent/plugins/claude/subagents"
  mkdir -p "$project_root/intent/plugins/agents/templates"
  
  # 2. Migrate agents to plugin location
  if [ -d "$project_root/agents" ]; then
    echo "  Migrating agents to plugin location..."
    if [ "$(ls -A "$project_root/agents" 2>/dev/null)" ]; then
      cp -r "$project_root/agents/"* "$project_root/intent/plugins/claude/subagents/" 2>/dev/null || true
    fi
    # Keep old agents directory for now, will be cleaned up later
  fi
  
  # 3. Create AGENTS.md at project root if it doesn't exist.
  # Canon since v2.10.0: root AGENTS.md is a real file (no symlink, no intent/llm/ copy).
  if [ ! -f "$project_root/AGENTS.md" ]; then
    echo "  Generating AGENTS.md..."

    if [ -f "$INTENT_HOME/bin/intent" ] && [ -f "$INTENT_HOME/intent/plugins/agents/bin/intent_agents" ]; then
      if (cd "$project_root" && "$INTENT_HOME/bin/intent" agents generate > "AGENTS.md" 2>/dev/null) && [ -s "$project_root/AGENTS.md" ]; then
        echo "    Generated project-specific AGENTS.md"
      else
        _generate_basic_agents_md "$project_root"
      fi
    else
      _generate_basic_agents_md "$project_root"
    fi
  else
    echo "  AGENTS.md already exists, skipping generation"
  fi
  
  # 4. Update .intent/config.json
  if [ -f "$project_root/.intent/config.json" ]; then
    echo "  Updating configuration for v$target_version..."
    local temp_file=$(mktemp)
    jq --arg v "$target_version" '.intent_version = $v | del(.version) | .plugins = {"claude": {"subagents_path": "intent/plugins/claude/subagents"}, "agents": {"config_path": "intent/plugins/agents"}}' "$project_root/.intent/config.json" > "$temp_file"
    mv "$temp_file" "$project_root/.intent/config.json"
  fi
  
  # 5. Update CLAUDE.md with new commands
  if [ -f "$project_root/CLAUDE.md" ]; then
    echo "  Updating CLAUDE.md with v$target_version commands..."
    # Update agent commands to claude subagents
    sed -i.bak 's/`intent agents init`/`intent claude subagents init`/g' "$project_root/CLAUDE.md"
    sed -i.bak 's/`intent agents list`/`intent claude subagents list`/g' "$project_root/CLAUDE.md"
    sed -i.bak 's/`intent agents install/`intent claude subagents install/g' "$project_root/CLAUDE.md"
    rm -f "$project_root/CLAUDE.md.bak"
  fi
  
  echo "  Migration to v$target_version complete!"
  echo ""
  echo "  IMPORTANT CHANGES IN v2.3.0:"
  echo "    - 'intent agents' commands are now 'intent claude subagents'"
  echo "    - New 'intent agents' commands manage AGENTS.md"
  echo "    - Subagents moved to intent/plugins/claude/subagents/"
  echo "    - AGENTS.md provides universal AI agent instructions"
}

# Migrate v2.3.0 to v2.3.1 - Worker-bee agent integration
migrate_v2_3_0_to_v2_3_1() {
  local project_root=$1
  
  local target_version="$(get_intent_version 2>/dev/null || echo "2.3.2")"
  echo "Upgrading to Intent v$target_version with worker-bee agent..."
  
  # Update .intent/config.json to target version
  if [ -f "$project_root/.intent/config.json" ]; then
    echo "  Updating project version to $target_version..."
    local temp_file=$(mktemp)
    jq --arg v "$target_version" '.intent_version = $v | del(.version)' "$project_root/.intent/config.json" > "$temp_file"
    mv "$temp_file" "$project_root/.intent/config.json"
  fi
  
  # Check if worker-bee agent needs to be added to manifest
  if [ -f "$project_root/intent/plugins/claude/subagents/.manifest/global-agents.json" ]; then
    if ! grep -q "worker-bee" "$project_root/intent/plugins/claude/subagents/.manifest/global-agents.json"; then
      echo "  Adding worker-bee agent to global manifest..."
      # This would normally be done by the Intent installation, but we document it
      echo "    Note: Run 'intent claude subagents list' to see worker-bee agent"
    fi
  fi
  
  # Update CLAUDE.md if it exists and doesn't mention worker-bee
  if [ -f "$project_root/CLAUDE.md" ]; then
    if ! grep -q "worker-bee" "$project_root/CLAUDE.md"; then
      echo "  Note: CLAUDE.md may need updating to include worker-bee agent"
      echo "        Run 'intent doctor' to check for any issues"
    fi
  fi
  
  echo "  Migration to v$target_version complete!"
  echo ""
  echo "  IMPORTANT CHANGES IN v2.3.1:"
  echo "    - Added worker-bee agent for Worker-Bee Driven Design (WDD)"
  echo "    - Worker-bee agent includes resources directory with Mix tasks and templates"
  echo "    - Run 'intent claude subagents install worker-bee' to install the agent"
}

# Update config version helper function
update_config_version() {
  local project_root=$1
  local target_version=$2
  
  if [ -f "$project_root/.intent/config.json" ]; then
    local temp_file=$(mktemp)
    jq --arg v "$target_version" '.intent_version = $v | del(.version)' "$project_root/.intent/config.json" > "$temp_file"
    mv "$temp_file" "$project_root/.intent/config.json"
  fi
}

