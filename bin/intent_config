#!/bin/bash
# intent_config - Shared configuration library for Intent
# Provides JSON parsing, config loading, and common functions
#
# This file is sourced by other scripts; it deliberately does not set `set -e`
# so callers retain control of strict-mode semantics.

# Source helpers for version function if available
if [ -z "$INTENT_HOME" ]; then
  INTENT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi
if [ -f "$INTENT_HOME/bin/intent_helpers" ]; then
  source "$INTENT_HOME/bin/intent_helpers"
fi

# Get version from centralized source
INTENT_VERSION="$(get_intent_version)"

# Default values
DEFAULT_INTENT_DIR="intent"

# read_config_field and find_project_root are sourced from
# bin/intent_helpers (Highlander, ST0042/WP-05).

# Load Intent configuration with hierarchy
load_intent_config() {
  # Initialize defaults (INTENT_VERSION already set above)
  INTENT_DIR="${DEFAULT_INTENT_DIR}"
  AUTHOR="${USER}"
  EDITOR="${EDITOR:-vim}"
  
  # Find project root (ignore exit code to prevent set -e from exiting)
  PROJECT_ROOT=$(find_project_root || true)
  
  # Load global config (XDG standard location)
  local config_file value
  config_file="$HOME/.config/intent/config.json"
  if [ -f "$config_file" ]; then
    value=$(read_config_field "$config_file" "intent_dir") && [ -n "$value" ] && INTENT_DIR="$value"
    value=$(read_config_field "$config_file" "author") && [ -n "$value" ] && AUTHOR="$value"
    value=$(read_config_field "$config_file" "editor") && [ -n "$value" ] && EDITOR="$value"
  fi

  # Load local config (overrides global)
  config_file="$PROJECT_ROOT/intent/.config/config.json"
  if [ -n "$PROJECT_ROOT" ] && [ -f "$config_file" ]; then
    value=$(read_config_field "$config_file" "intent_dir") && [ -n "$value" ] && INTENT_DIR="$value"
    value=$(read_config_field "$config_file" "author") && [ -n "$value" ] && AUTHOR="$value"
    value=$(read_config_field "$config_file" "editor") && [ -n "$value" ] && EDITOR="$value"
    value=$(read_config_field "$config_file" "intent_version") && [ -n "$value" ] && INTENT_VERSION="$value"
  fi
  
  # Environment variables override all
  [ -n "$INTENT_DIR_OVERRIDE" ] && INTENT_DIR="$INTENT_DIR_OVERRIDE"
  
  # Legacy support: check for stp directory if intent doesn't exist
  if [ -n "$PROJECT_ROOT" ]; then
    if [ ! -d "$PROJECT_ROOT/$INTENT_DIR" ] && [ -d "$PROJECT_ROOT/stp" ]; then
      INTENT_DIR="stp"
    fi
  fi
  
  # Export for use in subcommands
  export INTENT_VERSION INTENT_DIR AUTHOR EDITOR PROJECT_ROOT
}

# Validate JSON syntax using jq
validate_json() {
  local file=$1
  
  if [ ! -f "$file" ]; then
    return 1
  fi
  
  require_jq 2>/dev/null || return 1
  
  # Use jq to validate JSON syntax
  if jq . "$file" >/dev/null 2>&1; then
    return 0
  else
    return 1
  fi
}

# Display configuration (for debugging)
show_config() {
  echo "Intent Configuration:"
  echo "  INTENT_VERSION: $INTENT_VERSION"
  echo "  PROJECT_ROOT: ${PROJECT_ROOT:-<not in project>}"
  echo "  INTENT_DIR: $INTENT_DIR"
  echo "  AUTHOR: $AUTHOR"
  echo "  EDITOR: $EDITOR"
}

# Create default global config
create_default_global_config() {
  local config_dir="$HOME/.config/intent"
  local config_file="$config_dir/config.json"
  
  mkdir -p "$config_dir"
  
  cat > "$config_file" << EOF
{
  "intent_version": "2.1.0",
  "intent_dir": "intent",
  "author": "${USER}",
  "editor": "${EDITOR:-vim}"
}
EOF
  
  return $?
}

# Determine if running in legacy mode
is_legacy_project() {
  if [ -n "$PROJECT_ROOT" ]; then
    # Check for old structures
    if [ -f "$PROJECT_ROOT/.stp-config" ] || [ -d "$PROJECT_ROOT/stp" ]; then
      if [ ! -f "$PROJECT_ROOT/intent/.config/config.json" ]; then
        return 0
      fi
    fi
  fi
  return 1
}

# warning() is sourced from bin/intent_helpers (Highlander).

# Export functions for use by other scripts
# (read_config_field / find_project_root are exported by intent_helpers)
export -f load_intent_config
export -f validate_json
export -f show_config
export -f create_default_global_config
export -f is_legacy_project