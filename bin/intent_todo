#!/bin/bash
# intent_todo - A flat DOING / TODO / DONE view of steel threads and work packages
# Copyright (c) 2026 Matthew Sinclair
# Licensed under the MIT License (see LICENSE file)
# Usage: intent todo [command] [arguments]
#
# The view is a PROJECTION of each thread's real status (intent/st/**): the
# checkbox glyphs are rendered from the `status:` frontmatter, never stored
# independently, so intent/todo.md cannot drift from the steel-thread state.

# Exit on error
set -e

# Source shared helpers (Highlander: resolve_st_dir, normalise_st_id, error, ...)
: "${INTENT_HOME:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$INTENT_HOME/bin/intent_helpers"

ST_BASE="intent/st"
TODO_FILE="intent/todo.md"

usage() {
  echo "Usage: intent todo [command] [arguments]"
  echo ""
  echo "A flat DOING / TODO / DONE view of steel threads and work packages,"
  echo "projected from each thread's real status. The file lives at intent/todo.md."
  echo ""
  echo "Commands:"
  echo "  (none), list          Show intent/todo.md (generates it if absent)"
  echo "  update                Regenerate intent/todo.md from current status"
  echo "  done <STID[/NN]>      Mark a thread/WP done (via intent st/wp done), then regenerate"
  echo "  notdone <STID[/NN]>   Reopen a thread/WP to WIP, then regenerate"
  echo "  toggle <STID[/NN]>    Flip done/not-done, then regenerate"
  echo "  help                  Show this help"
  echo ""
  echo "Options:"
  echo "  --json                Emit the DOING/TODO/DONE view as JSON (stdout)"
  echo ""
  echo "Checkbox legend:  [ ] not started   [-] in progress   [x] done"
  echo ""
  echo "Buckets:"
  echo "  DOING   steel threads with status WIP (+ their work packages)"
  echo "  TODO    steel threads not yet started"
  echo "  DONE    steel threads completed today (swept to history daily)"
  exit 1
}

# Map an Intent status value to a checkbox glyph. Steel threads use
# WIP / Not Started / Completed / Cancelled; work packages use WIP / Not
# Started / Done -- both vocabularies are handled here (Highlander).
status_box() {
  case "$1" in
  WIP) printf -- '-' ;;
  "Not Started") printf ' ' ;;
  Done | Completed) printf 'x' ;;
  Cancelled) printf '~' ;;
  *) printf '?' ;;
  esac
}

# Read one frontmatter field ($2) from an info.md ($1). The pipeline ends in
# sed, so a no-match grep does not trip `set -e`. Strips surrounding quotes.
field() {
  grep -m 1 "^$2:" "$1" 2>/dev/null | sed "s/^$2: *//; s/^\"//; s/\"$//"
}

# A steel thread's title is its `# ST####: Title` heading (no title: frontmatter).
st_title() {
  grep -m 1 "^# ST[0-9]" "$1/info.md" 2>/dev/null | sed 's/^# ST[0-9]*: *//'
}

# Emit one steel-thread block: the ST line plus its work-package lines.
emit_st_block() {
  local st_dir="$1"
  local st_id status box title hold tag
  st_id=$(basename "$st_dir")
  status=$(field "$st_dir/info.md" status)
  box=$(status_box "$status")
  title=$(st_title "$st_dir")

  # hv convention: an on-hold thread keeps status: WIP + on-hold: TRUE.
  hold=$(field "$st_dir/info.md" "on-hold")
  tag=""
  case "$hold" in
  [Tt][Rr][Uu][Ee]) tag=" (on-hold)" ;;
  esac

  # Emit as a GitHub-Flavored-Markdown task-list item ("- [ ]"), so the file
  # is prettier-stable (plain "[-] ..." lines get reflowed into one paragraph)
  # and renders as a real nested checklist. Content is a data arg to
  # `printf '%s\n'` so a leading "-" glyph or a "%" in a title stays literal.
  printf '%s\n' "- [$box] $st_id: $title$tag"

  [ -d "$st_dir/WP" ] || return 0
  local wp wn ws wt wb
  for wp in "$st_dir/WP"/[0-9][0-9]; do
    [ -d "$wp" ] && [ -f "$wp/info.md" ] || continue
    wn=$(basename "$wp")
    ws=$(field "$wp/info.md" status)
    wt=$(field "$wp/info.md" title)
    wb=$(status_box "$ws")
    printf '%s\n' "  - [$wb] $wn: $wt"
  done
}

# Emit every steel-thread block under a status directory ($1), in ST-number
# order (the glob expands zero-padded, so lexical == numeric).
emit_bucket() {
  local root="$1" st
  for st in "$root"/ST[0-9]*; do
    [ -d "$st" ] && [ -f "$st/info.md" ] || continue
    emit_st_block "$st"
  done
}

# Emit completed threads whose `completed:` date is today (the live DONE view;
# older completions live permanently in COMPLETED/ and the monthly done-log).
emit_done_today() {
  local today st comp
  today=$(date '+%Y%m%d')
  for st in "$ST_BASE/COMPLETED"/ST[0-9]*; do
    [ -d "$st" ] && [ -f "$st/info.md" ] || continue
    comp=$(field "$st/info.md" completed)
    comp="${comp//[^0-9]/}"
    [ "$comp" = "$today" ] || continue
    emit_st_block "$st"
  done
}

# Regenerate intent/todo.md atomically (temp file + mv).
# shellcheck disable=SC2016  # backticks in the printf strings are literal markdown, not command substitution
generate() {
  local tmp doing todo done_today
  doing=$(emit_bucket "$ST_BASE" || true)
  todo=$(emit_bucket "$ST_BASE/NOT-STARTED" || true)
  done_today=$(emit_done_today || true)

  tmp=$(mktemp)
  {
    printf '## DOING\n\n'
    if [ -n "$doing" ]; then printf '%s\n' "$doing"; else printf '_(none)_\n'; fi

    printf '\n## TODO\n\n'
    if [ -n "$todo" ]; then printf '%s\n' "$todo"; else printf '_(none)_\n'; fi

    printf '\n## DONE\n\n'
    if [ -n "$done_today" ]; then printf '%s\n' "$done_today"; else printf '_(none)_\n'; fi
  } >"$tmp"

  mv "$tmp" "$TODO_FILE"
}

# ---- JSON projection (--json export) ----
# The JSON and markdown views share the same field extraction (field / st_title)
# and the same bucket->directory mapping; only the rendering differs (Highlander).

# One steel thread as a JSON object: id, title, status, work_packages[].
emit_st_json() {
  local st_dir="$1" st_id status title wps="[]"
  st_id=$(basename "$st_dir")
  status=$(field "$st_dir/info.md" status)
  title=$(st_title "$st_dir")

  if [ -d "$st_dir/WP" ]; then
    local wp wn ws wt
    for wp in "$st_dir/WP"/[0-9][0-9]; do
      [ -d "$wp" ] && [ -f "$wp/info.md" ] || continue
      wn=$(basename "$wp")
      ws=$(field "$wp/info.md" status)
      wt=$(field "$wp/info.md" title)
      wps=$(printf '%s' "$wps" | jq --arg id "$wn" --arg title "$wt" --arg status "$ws" \
        '. + [{id: $id, title: $title, status: $status}]')
    done
  fi

  jq -n --arg id "$st_id" --arg title "$title" --arg status "$status" --argjson wps "$wps" \
    '{id: $id, title: $title, status: $status, work_packages: $wps}'
}

# A JSON array of the steel threads directly under a status directory ($1).
emit_bucket_json() {
  local root="$1" st out="[]"
  for st in "$root"/ST[0-9]*; do
    [ -d "$st" ] && [ -f "$st/info.md" ] || continue
    out=$(printf '%s' "$out" | jq --argjson obj "$(emit_st_json "$st")" '. + [$obj]')
  done
  printf '%s' "$out"
}

# A JSON array of the threads completed today (the DONE bucket).
emit_done_today_json() {
  local today st comp out="[]"
  today=$(date '+%Y%m%d')
  for st in "$ST_BASE/COMPLETED"/ST[0-9]*; do
    [ -d "$st" ] && [ -f "$st/info.md" ] || continue
    comp=$(field "$st/info.md" completed)
    comp="${comp//[^0-9]/}"
    [ "$comp" = "$today" ] || continue
    out=$(printf '%s' "$out" | jq --argjson obj "$(emit_st_json "$st")" '. + [$obj]')
  done
  printf '%s' "$out"
}

# The whole view as keyed-by-bucket JSON: { doing:[...], todo:[...], done:[...] }.
generate_json() {
  require_jq || exit 1
  local doing todo done_today
  doing=$(emit_bucket_json "$ST_BASE")
  todo=$(emit_bucket_json "$ST_BASE/NOT-STARTED")
  done_today=$(emit_done_today_json)
  jq -n --argjson doing "$doing" --argjson todo "$todo" --argjson donev "$done_today" \
    '{doing: $doing, todo: $todo, done: $donev}'
}

# ---- Mutation verbs (done / notdone / toggle) ----
# These change REAL status by delegating to intent st / intent wp, then
# regenerate the view -- never hand-editing a checkbox (the projection invariant).

# Resolve a spec (STID or STID/NN) to its info.md path (shared parser).
spec_info_file() {
  parse_wp_specifier "$1" "false"   # sets ST_ID, WP_NUM (Highlander helper)
  local st_dir
  st_dir=$(resolve_st_dir "$ST_ID") || error "steel thread not found: $ST_ID"
  if [ -n "$WP_NUM" ]; then
    echo "$st_dir/WP/$WP_NUM/info.md"
  else
    echo "$st_dir/info.md"
  fi
}

# Route a mutation to intent st / intent wp (a WP when the spec has /NN), then
# regenerate. intent st/wp done enforce the acceptance close-gate, so `done`
# inherits it (D2): a BLOCKED contract aborts here under set -e with the gate's
# message, and the status is left unchanged.
todo_mutate() {
  local verb="$1" spec="$2"
  [ -n "$spec" ] || error "usage: intent todo <done|notdone|toggle> <STID[/NN]>"
  if [[ "$spec" == */* ]]; then
    "$INTENT_HOME/bin/intent" wp "$verb" "$spec"
  else
    "$INTENT_HOME/bin/intent" st "$verb" "$spec"
  fi
  generate
}

# ---- Command dispatch ----

if [ ! -d "$ST_BASE" ]; then
  error "no $ST_BASE directory here -- run from an Intent project (intent todo)."
fi

# --json is a stdout export mode for the default / list view (update writes md).
JSON_MODE=0
ARGS=()
for arg in "$@"; do
  case "$arg" in
  --json) JSON_MODE=1 ;;
  *) ARGS+=("$arg") ;;
  esac
done
set -- ${ARGS[@]+"${ARGS[@]}"}

COMMAND="${1:-list}"
[ $# -gt 0 ] && shift

case "$COMMAND" in
list)
  if [ "$JSON_MODE" -eq 1 ]; then
    generate_json
  elif [ -f "$TODO_FILE" ]; then
    cat "$TODO_FILE"
  else
    info "no $TODO_FILE yet -- generating..."
    generate
    cat "$TODO_FILE"
  fi
  ;;
update)
  generate
  info "updated: $TODO_FILE"
  ;;
done)
  todo_mutate "done" "$1"
  ;;
notdone)
  todo_mutate "start" "$1"
  ;;
toggle)
  spec="$1"
  [ -n "$spec" ] || error "usage: intent todo toggle <STID[/NN]>"
  case "$(field "$(spec_info_file "$spec")" status)" in
  Done | Completed) todo_mutate "start" "$spec" ;;
  *) todo_mutate "done" "$spec" ;;
  esac
  ;;
help | --help | -h)
  usage
  ;;
*)
  error "Unknown todo command: $COMMAND. Run 'intent todo help' for usage."
  ;;
esac
