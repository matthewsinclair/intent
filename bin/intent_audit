#!/bin/bash
# intent_audit - Automated code quality checks for Elixir projects
# Usage: intent audit <command> [options]

# Exit on error
set -e

# Source shared helpers
: "${INTENT_HOME:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$INTENT_HOME/bin/intent_helpers"

# Template source directory
CHECKS_TEMPLATE_DIR="$INTENT_HOME/lib/templates/credo_checks/elixir"

# Target directory in the project
CHECKS_TARGET_DIR="lib/mix/checks"

# Valid rules list
VALID_RULES="R2 R6 R7 R8 R11 R15"

# Rules that support auto-fix
FIXABLE_RULES="R8 R11 R15"

# ============================================================
# Rule -> Template Mapping (bash 3.x compatible)
# ============================================================

get_rule_template() {
  local rule="$1"
  case "$rule" in
    R2)  echo "thick_coordinator.ex" ;;
    R6)  echo "highlander_suspect.ex" ;;
    R7)  echo "map_get_on_struct.ex" ;;
    R8)  echo "boolean_operators.ex" ;;
    R11) echo "missing_impl_annotation.ex" ;;
    R15) echo "debug_artifacts.ex" ;;
    *)   return 1 ;;
  esac
}

is_valid_rule() {
  local rule="$1"
  case "$rule" in
    R2|R6|R7|R8|R11|R15) return 0 ;;
    *) return 1 ;;
  esac
}

# ============================================================
# Usage
# ============================================================

usage() {
  echo "Usage: intent audit <command> [options]"
  echo ""
  echo "Run automated code quality checks on Elixir projects."
  echo ""
  echo "Commands:"
  echo "  quick              Run Credo with Intent custom checks"
  echo "  health             Lightweight periodic health check"
  echo "  help               Show this help"
  echo ""
  echo "Options (for quick):"
  echo "  --rule RN          Run only the specified rule (R2, R6, R7, R8, R11, R15)"
  echo "  --fix              Apply auto-fixes for fixable rules (R8, R11, R15)"
  echo "  --json             Output results as JSON"
  echo "  --checks-only      Only copy check templates, don't run credo"
  echo ""
  echo "Options (for health):"
  echo "  --report           Save markdown report to intent/audit/"
  echo "  --diff             Only check files changed since last health check"
  echo ""
  echo "Rules:"
  echo "  R2   Thick coordinator (controllers/LiveViews exceeding line limit)"
  echo "  R6   Highlander suspect (same function name in multiple modules)"
  echo "  R7   Map.get on struct (use dot access instead)"
  echo "  R8   Boolean operators (use and/or for booleans)"
  echo "  R11  Missing @impl annotation on callbacks"
  echo "  R15  Debug artifacts (IO.inspect, dbg, IO.puts in lib/)"
  echo ""
  echo "Examples:"
  echo "  intent audit quick                  # Run all checks"
  echo "  intent audit quick --rule R8        # Run only boolean operator check"
  echo "  intent audit quick --fix            # Auto-fix fixable rules"
  echo "  intent audit quick --json           # JSON output"
  echo "  intent audit quick --checks-only    # Just install check templates"
  echo "  intent audit health                 # Run health check"
  echo "  intent audit health --report        # Save markdown report"
  echo "  intent audit health --diff          # Only check changed files"
  exit 0
}

# ============================================================
# Check Prerequisites
# ============================================================

require_mix_project() {
  if [ ! -f "mix.exs" ]; then
    error "No mix.exs found. The audit command requires an Elixir/Mix project."
  fi
}

require_credo() {
  if ! mix deps 2>/dev/null | grep -q "credo"; then
    echo "Warning: Credo dependency not found in mix.exs." >&2
    echo "" >&2
    echo "Add {:credo, \"~> 1.7\", only: [:dev, :test], runtime: false} to your deps." >&2
    echo "" >&2
    return 1
  fi
  return 0
}

# ============================================================
# Template Management
# ============================================================

# Copy check templates to project if missing
ensure_checks_installed() {
  local copied=0

  if [ ! -d "$CHECKS_TEMPLATE_DIR" ]; then
    error "Check templates not found at $CHECKS_TEMPLATE_DIR. Intent installation may be corrupted."
  fi

  # Create target directory if needed
  if [ ! -d "$CHECKS_TARGET_DIR" ]; then
    echo "Creating $CHECKS_TARGET_DIR/..."
    mkdir -p "$CHECKS_TARGET_DIR"
    copied=1
  fi

  # Copy any missing templates
  for template in "$CHECKS_TEMPLATE_DIR"/*.ex; do
    local basename
    basename=$(basename "$template")
    if [ ! -f "$CHECKS_TARGET_DIR/$basename" ]; then
      cp "$template" "$CHECKS_TARGET_DIR/$basename"
      echo "  Installed check: $basename"
      copied=$((copied + 1))
    fi
  done

  if [ "$copied" -gt 0 ]; then
    echo "  $copied check(s) installed to $CHECKS_TARGET_DIR/"
    echo ""
  fi
}

# ============================================================
# Credo Integration
# ============================================================

run_credo() {
  local rule_filter="$1"
  local json_mode="$2"
  local fix_mode="$3"

  local credo_args="--strict --checks-dir $CHECKS_TARGET_DIR"

  # Filter to specific check if rule specified
  if [ -n "$rule_filter" ]; then
    local template_file
    template_file=$(get_rule_template "$rule_filter") || {
      error "Unknown rule: $rule_filter. Valid rules: $VALID_RULES"
    }

    # Extract module name from template file
    local check_module
    check_module=$(grep "^defmodule" "$CHECKS_TARGET_DIR/$template_file" 2>/dev/null | head -1 | sed 's/defmodule \(.*\) do/\1/')

    if [ -n "$check_module" ]; then
      credo_args="$credo_args --checks $check_module"
    fi
  fi

  # JSON output mode
  if [ "$json_mode" = "true" ]; then
    credo_args="$credo_args --format json"
  fi

  echo "Running Credo with Intent checks..."
  echo ""

  # Run credo and capture output
  local exit_code=0
  local credo_output
  credo_output=$(eval mix credo $credo_args 2>&1) || exit_code=$?

  if [ "$json_mode" = "true" ]; then
    echo "$credo_output"
  else
    format_report "$credo_output" "$exit_code" "$rule_filter" "$fix_mode"
  fi

  return $exit_code
}

# ============================================================
# Report Formatting
# ============================================================

format_report() {
  local credo_output="$1"
  local exit_code="$2"
  local rule_filter="$3"
  local fix_mode="$4"

  local width
  width=$(get_terminal_width)
  local separator
  separator=$(printf '%*s' "$width" '' | tr ' ' '-')

  echo "$separator"
  echo "Intent Audit Report"
  echo "$separator"
  echo ""

  if [ -n "$rule_filter" ]; then
    echo "Rule filter: $rule_filter"
    echo ""
  fi

  # Display credo output
  echo "$credo_output"

  echo ""
  echo "$separator"

  if [ "$exit_code" -eq 0 ]; then
    echo "Result: PASS -- no issues found"
  else
    echo "Result: ISSUES FOUND"

    if [ "$fix_mode" = "true" ]; then
      echo ""
      echo "Note: Auto-fix requested but Credo auto-fix requires manual application."
      echo "Review the issues above and apply fixes as needed."
    fi
  fi

  echo "$separator"
}

# ============================================================
# Command: quick
# ============================================================

cmd_quick() {
  local rule_filter=""
  local json_mode="false"
  local fix_mode="false"
  local checks_only="false"

  # Parse options
  while [ $# -gt 0 ]; do
    case "$1" in
      --rule)
        [ $# -lt 2 ] && error "Missing argument for --rule"
        rule_filter="$2"
        shift 2
        ;;
      --json)
        json_mode="true"
        shift
        ;;
      --fix)
        fix_mode="true"
        shift
        ;;
      --checks-only)
        checks_only="true"
        shift
        ;;
      *)
        error "Unknown option: $1. Run 'intent audit help' for usage."
        ;;
    esac
  done

  # Validate rule if specified
  if [ -n "$rule_filter" ]; then
    local upper_rule
    upper_rule=$(echo "$rule_filter" | tr '[:lower:]' '[:upper:]')
    if ! is_valid_rule "$upper_rule"; then
      error "Unknown rule: $rule_filter. Valid rules: $VALID_RULES"
    fi
    rule_filter="$upper_rule"
  fi

  # Require mix project
  require_mix_project

  # Install check templates
  ensure_checks_installed

  # If checks-only, we're done
  if [ "$checks_only" = "true" ]; then
    echo "Check templates installed. Run 'mix credo --checks-dir $CHECKS_TARGET_DIR' manually."
    exit 0
  fi

  # Verify credo is available
  if ! require_credo; then
    exit 1
  fi

  # Run credo
  run_credo "$rule_filter" "$json_mode" "$fix_mode"
}

# ============================================================
# Command: health
# ============================================================

# Timestamp file for --diff mode
HEALTH_TIMESTAMP_FILE=".intent/last-health-check"

# Get changed files since last health check
get_changed_files() {
  local since_timestamp=""

  if [ -f "$HEALTH_TIMESTAMP_FILE" ]; then
    since_timestamp=$(cat "$HEALTH_TIMESTAMP_FILE")
  fi

  if [ -n "$since_timestamp" ]; then
    # Files changed since last health check (tracked files only)
    git diff --name-only "$since_timestamp" HEAD -- '*.ex' '*.exs' 2>/dev/null || true
    # Also include untracked .ex files
    git ls-files --others --exclude-standard -- '*.ex' '*.exs' 2>/dev/null || true
  else
    # No previous timestamp: check all tracked .ex/.exs files
    git ls-files -- '*.ex' '*.exs' 2>/dev/null || true
  fi
}

# Save current git HEAD as timestamp
save_health_timestamp() {
  local head_sha
  head_sha=$(git rev-parse HEAD 2>/dev/null) || return 0
  mkdir -p "$(dirname "$HEALTH_TIMESTAMP_FILE")"
  echo "$head_sha" > "$HEALTH_TIMESTAMP_FILE"
}

# Check for modules not registered in MODULES.md
check_modules_coverage() {
  local diff_only="$1"
  local issues=0

  # Find the MODULES.md file
  local modules_file=""
  if [ -f "intent/llm/MODULES.md" ]; then
    modules_file="intent/llm/MODULES.md"
  fi

  if [ -z "$modules_file" ]; then
    echo "  [SKIP] No MODULES.md found"
    return 0
  fi

  # Get list of .ex files to check
  local files_to_check
  if [ "$diff_only" = "true" ]; then
    files_to_check=$(get_changed_files | grep '^lib/' | grep '\.ex$' || true)
  else
    files_to_check=$(find lib -name '*.ex' -type f 2>/dev/null | sort || true)
  fi

  if [ -z "$files_to_check" ]; then
    echo "  [PASS] No lib/*.ex files to check"
    return 0
  fi

  # Extract module names from source files and check against MODULES.md
  local unregistered=""
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    # Extract the defmodule name
    local module_name
    module_name=$(grep -m1 "^defmodule " "$file" 2>/dev/null | sed 's/defmodule \([^ ]*\).*/\1/' || true)
    if [ -n "$module_name" ] && ! grep -q "$file" "$modules_file" 2>/dev/null; then
      unregistered="$unregistered\n    $file ($module_name)"
      issues=$((issues + 1))
    fi
  done <<< "$files_to_check"

  if [ "$issues" -gt 0 ]; then
    echo "  [WARN] $issues module(s) not in MODULES.md:$(echo -e "$unregistered")"
  else
    echo "  [PASS] All modules registered in MODULES.md"
  fi

  return $issues
}

# Check for thick coordinators (controllers/LiveViews over line limit)
check_thick_coordinators() {
  local diff_only="$1"
  local max_lines=100
  local issues=0

  local files_to_check
  if [ "$diff_only" = "true" ]; then
    files_to_check=$(get_changed_files | grep '^lib/' | grep '\.ex$' || true)
  else
    files_to_check=$(find lib -name '*.ex' -type f 2>/dev/null | sort || true)
  fi

  if [ -z "$files_to_check" ]; then
    echo "  [PASS] No lib/*.ex files to check"
    return 0
  fi

  local thick=""
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    # Check if it's a coordinator
    if grep -qE "use (Phoenix\.Controller|Phoenix\.LiveView|Phoenix\.LiveComponent)" "$file" 2>/dev/null; then
      local line_count
      line_count=$(wc -l < "$file" | tr -d ' ')
      if [ "$line_count" -gt "$max_lines" ]; then
        thick="$thick\n    $file ($line_count lines)"
        issues=$((issues + 1))
      fi
    fi
  done <<< "$files_to_check"

  if [ "$issues" -gt 0 ]; then
    echo "  [WARN] $issues thick coordinator(s) (>$max_lines lines):$(echo -e "$thick")"
  else
    echo "  [PASS] No thick coordinators found"
  fi

  return $issues
}

# Check for duplicate function names across modules
check_highlander_suspects() {
  local diff_only="$1"
  local issues=0

  local files_to_check
  if [ "$diff_only" = "true" ]; then
    files_to_check=$(get_changed_files | grep '^lib/' | grep '\.ex$' || true)
  else
    files_to_check=$(find lib -name '*.ex' -type f 2>/dev/null | sort || true)
  fi

  if [ -z "$files_to_check" ]; then
    echo "  [PASS] No lib/*.ex files to check"
    return 0
  fi

  # Collect all public def names with their files
  local common_names="new|get|list|create|update|delete|changeset|render|init|call|handle_call|handle_cast|handle_info|handle_event|mount|handle_params|terminate|code_change|start_link|child_spec"
  local defs_file
  defs_file=$(mktemp)

  while IFS= read -r file; do
    [ -z "$file" ] && continue
    grep -n "^  def [a-z]" "$file" 2>/dev/null | while IFS= read -r line; do
      local func_name
      func_name=$(echo "$line" | sed 's/.*def \([a-z_]*\).*/\1/')
      if ! echo "$func_name" | grep -qE "^($common_names)$"; then
        echo "$func_name|$file" >> "$defs_file"
      fi
    done
  done <<< "$files_to_check"

  # Find duplicates
  local duplicates=""
  if [ -s "$defs_file" ]; then
    local dup_names
    dup_names=$(cut -d'|' -f1 "$defs_file" | sort | uniq -d)
    if [ -n "$dup_names" ]; then
      while IFS= read -r name; do
        [ -z "$name" ] && continue
        local locations
        locations=$(grep "^${name}|" "$defs_file" | cut -d'|' -f2 | sort -u | tr '\n' ', ' | sed 's/,$//')
        duplicates="$duplicates\n    $name: $locations"
        issues=$((issues + 1))
      done <<< "$dup_names"
    fi
  fi

  rm -f "$defs_file"

  if [ "$issues" -gt 0 ]; then
    echo "  [WARN] $issues Highlander suspect(s):$(echo -e "$duplicates")"
  else
    echo "  [PASS] No Highlander suspects found"
  fi

  return $issues
}

cmd_health() {
  local report_mode="false"
  local diff_mode="false"

  # Parse options
  while [ $# -gt 0 ]; do
    case "$1" in
      --report)
        report_mode="true"
        shift
        ;;
      --diff)
        diff_mode="true"
        shift
        ;;
      *)
        error "Unknown option: $1. Run 'intent audit help' for usage."
        ;;
    esac
  done

  local width
  width=$(get_terminal_width)
  local separator
  separator=$(printf '%*s' "$width" '' | tr ' ' '-')
  local date_str
  date_str=$(date +%Y-%m-%d)
  local project_name
  project_name=$(basename "$(pwd)")

  # Build report output
  local report=""
  local total_issues=0

  report="$separator
Intent Health Check -- $project_name
Date: $date_str
$separator
"

  if [ "$diff_mode" = "true" ]; then
    if [ -f "$HEALTH_TIMESTAMP_FILE" ]; then
      local last_sha
      last_sha=$(cat "$HEALTH_TIMESTAMP_FILE")
      report="$report
Mode: diff (changes since $(echo "$last_sha" | cut -c1-8))
"
    else
      report="$report
Mode: diff (no previous check -- scanning all files)
"
    fi
  fi

  report="$report
Checks:
"

  # 1. Check if lib/ exists (Elixir project)
  if [ -d "lib" ]; then
    # 2. MODULES.md coverage
    local modules_result
    modules_result=$(check_modules_coverage "$diff_mode" 2>&1) || total_issues=$((total_issues + $?))
    report="$report$modules_result
"

    # 3. Thick coordinators
    local thick_result
    thick_result=$(check_thick_coordinators "$diff_mode" 2>&1) || total_issues=$((total_issues + $?))
    report="$report$thick_result
"

    # 4. Highlander suspects
    local highlander_result
    highlander_result=$(check_highlander_suspects "$diff_mode" 2>&1) || total_issues=$((total_issues + $?))
    report="$report$highlander_result
"

    # 5. Credo checks (if mix.exs and credo available)
    if [ -f "mix.exs" ] && mix deps 2>/dev/null | grep -q "credo"; then
      ensure_checks_installed 2>/dev/null
      local credo_result
      local credo_exit=0
      credo_result=$(mix credo --strict --checks-dir "$CHECKS_TARGET_DIR" 2>&1) || credo_exit=$?
      if [ "$credo_exit" -eq 0 ]; then
        report="$report  [PASS] Credo checks passed
"
      else
        local credo_issue_count
        credo_issue_count=$(echo "$credo_result" | grep -cE '^\[' 2>/dev/null || echo "0")
        report="$report  [WARN] Credo: $credo_issue_count issue(s) found
"
        total_issues=$((total_issues + 1))
      fi
    else
      report="$report  [SKIP] Credo not available (no mix.exs or credo dependency)
"
    fi
  else
    report="$report  [SKIP] No lib/ directory found (not an Elixir project?)
"
  fi

  report="$report
$separator
"

  if [ "$total_issues" -eq 0 ]; then
    report="${report}Result: HEALTHY -- no issues found
"
  else
    report="${report}Result: $total_issues area(s) need attention
"
  fi

  report="$report$separator"

  # Output report
  echo "$report"

  # Save report if requested
  if [ "$report_mode" = "true" ]; then
    local report_dir="intent/audit"
    mkdir -p "$report_dir"
    local report_file="$report_dir/$(date +%Y%m%d)-health.md"
    echo "$report" > "$report_file"
    echo ""
    echo "Report saved to: $report_file"
  fi

  # Update timestamp
  save_health_timestamp

  if [ "$total_issues" -gt 0 ]; then
    return 1
  fi
  return 0
}

# ============================================================
# Main Dispatch
# ============================================================

if [ $# -eq 0 ]; then
  usage
fi

SUBCOMMAND="$1"
shift

case "$SUBCOMMAND" in
  quick)
    cmd_quick "$@"
    ;;
  health)
    cmd_health "$@"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    error "Unknown audit command: $SUBCOMMAND. Run 'intent audit help' for usage."
    ;;
esac
