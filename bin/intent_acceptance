#!/bin/bash
# intent_acceptance - AC/AT instrumentation over acceptance.md (ST0044 WP-03).
#
# Serves the `ac` and `at` nouns (re-injected as $1 by bin/intent dispatch).
# acceptance.md is the single source of truth: this module reads and writes
# ONLY that file, editing status in place (linter-stable -- one line changes).
#
# Grammar (model A):
#   - AC-<gg>.<n> [(non-test)] <prose>[ -- evidence: <ref> -- satisfied: yes|no]
#   - AT-<gg>.<n> `<path>::<name>` -- covers <ac>[, <ac>...] -- status: <state>[ (note)]
# <state>: to-write | red | green | n/a. `green` is reachable only from `red`.
# A non-test AC is satisfied by its inline `satisfied: yes`; a test-backed AC
# is satisfied (computed) iff a covering AT is green. No `set -e`: the parser
# helpers return 0/1 as booleans; every real failure routes through error().

: "${INTENT_HOME:=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$INTENT_HOME/bin/intent_helpers"

usage() {
  echo "Usage: intent ac <command> <stid> [args]   |   intent at <command> <stid> <atid>"
  echo ""
  echo "ac commands:"
  echo "  list <stid>[/NN]                           List ACs + covering AT + satisfied state"
  echo "  status <stid>                              Report N/M satisfied + verdict (PASS/BLOCKED)"
  echo "  satisfy <stid> <acid> --evidence \"<ref>\"    Satisfy a non-test AC by named evidence"
  echo "  gate <stid>[/NN]                           Close-gate: exit non-zero + BLOCKED if unsatisfied"
  echo ""
  echo "at commands:"
  echo "  list <stid>[/NN]                           List ATs (id, path::name, status)"
  echo "  red|green|na <stid> <atid>                 Set AT status (green reachable only from red)"
  echo "  done|notdone <stid> <atid>                 Aliases for green | red"
  exit 1
}

# ---- field extraction (one AC/AT line in, one token out) ----------------

line_id()       { echo "$1" | sed -E 's/^- ([A-Z]+-[0-9]+\.[0-9]+).*/\1/'; }
id_group()      { echo "$1" | sed -E 's/^[A-Z]+-([0-9]+)\..*/\1/'; }
at_pathname()   { echo "$1" | sed -E 's/^[^`]*`([^`]*)`.*/\1/'; }
at_status()     { echo "$1" | sed -E 's/.* -- status: ([a-z/-]+).*/\1/'; }
at_covers()     { echo "$1" | sed -E 's/.* -- covers (.*) -- status:.*/\1/' | tr ',' ' '; }
ac_flag()       { echo "$1" | sed -E 's/.* -- satisfied: ([a-z]+).*/\1/'; }
ac_is_nontest() { case "$1" in *"(non-test)"*) return 0 ;; *) return 1 ;; esac; }

# ---- whole-file selectors ------------------------------------------------

ac_lines() { grep -E '^- AC-[0-9]+\.[0-9]+ ' "$1" 2>/dev/null || true; }
at_lines() { grep -E '^- AT-[0-9]+\.[0-9]+ ' "$1" 2>/dev/null || true; }

# Value of the frontmatter `acceptance:` key (empty if absent). Mirrors the
# house pattern for reading a steel-thread frontmatter scalar (cf the `status:`
# read in bin/intent_st). `exempt` is the explicit, visible opt-out the
# close-gate honours -- the only way an empty/missing contract passes.
acceptance_field() { grep -m1 -E '^acceptance:' "$1" 2>/dev/null | sed -E 's/^acceptance:[[:space:]]*//'; }

# AC/AT-shaped lines (start "- AC-"/"- AT-") that FAIL the strict numeric grammar.
# Without this guard they are silently dropped and the gate goes vacuous -- the
# exact failure that let a half-authored contract read as PASS. No Silent Errors.
malformed_acat() {
  grep -nE '^- A[CT]-' "$1" 2>/dev/null | grep -vE ':- A[CT]-[0-9]+\.[0-9]+ ' || true
}

# Warn (stderr) for each malformed AC/AT line; return 1 if any were found.
warn_malformed() {
  local acc="$1" bad line
  bad="$(malformed_acat "$acc")"
  [ -z "$bad" ] && return 0
  warning "malformed AC/AT line(s) in $acc -- id must be AC-<n>.<n> / AT-<n>.<n> (digits) then a space; these are NOT counted:"
  while IFS= read -r line; do
    [ -n "$line" ] && warning "  $line"
  done <<EOF
$bad
EOF
  return 1
}

# Single AC/AT line for an exact id (dots escaped), or empty.
find_line() {
  local esc
  esc="$(echo "$1" | sed 's/\./\\./g')"
  grep -E "^- ${esc} " "$2" 2>/dev/null | head -n1
}

# ---- resolution + targets ------------------------------------------------

# THE target resolver for the whole ac/at family (Highlander, issue 0004).
# "<stid>[/NN]" in; ST_ID, WP_NUM (padded) and TARGET_DIR out.
#
# Resolution is a distinct, FAILABLE step that must run BEFORE evaluation.
# Without it an unresolvable target degrades to an empty AC set, and each
# command then reports its own flavour of vacuous success over that emptiness:
# the gate found nothing unsatisfied and exited 0, `status` printed 0/0, `list`
# printed no rows. "This target does not exist" and "this target has nothing
# unsatisfied" were the same internal state, and only the second was ever
# reported. Resolving per-subcommand is how the gate came to lack even the
# steel-thread check its own sibling `status` had, so it resolves here once.
#
# The `/NN` segment is validated too -- nothing validated it anywhere before.
# On failure the reason lands in TARGET_REASON (a global, not stdout: callers
# capturing stdout in a subshell would lose every assignment above) and the
# caller picks the presentation -- error() for the human-facing readers, a
# BLOCKED line for the machine-facing gate.
resolve_target() {
  TARGET_REASON=""
  TARGET_DIR=""
  parse_wp_specifier "$1" "false"
  if ! TARGET_DIR="$(resolve_st_dir "$ST_ID")"; then
    TARGET_REASON="no such steel thread: $ST_ID"
    return 1
  fi
  if [ -n "$WP_NUM" ] && ! resolve_wp_dir "$TARGET_DIR" "$WP_NUM" >/dev/null; then
    TARGET_REASON="no such work package: $ST_ID/$WP_NUM"
    return 1
  fi
  return 0
}

# The contract file of an already-resolved target. resolve_target runs first.
acc_file() {
  local acc="$TARGET_DIR/acceptance.md"
  [ -f "$acc" ] || error "no acceptance.md for $ST_ID (looked in $TARGET_DIR)"
  echo "$acc"
}

# Resolve for the reader commands (list / status / satisfy / at): a bad target
# is a hard error, never an empty result set that reads as "nothing to report".
resolve_or_die() {
  resolve_target "$1" || error "$TARGET_REASON"
}

in_wp_filter() {
  [ -z "$WP_NUM" ] && return 0
  [ "$((10#$(id_group "$1")))" -eq "$((10#$WP_NUM))" ]
}

# ---- coverage + satisfaction --------------------------------------------

# Space-prefixed list of AT ids that cover the given AC id.
ac_covering_ats() {
  local id="$1" acc="$2" line out=""
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    case " $(at_covers "$line") " in
      *" $id "*) out="$out $(line_id "$line")" ;;
    esac
  done <<EOF
$(at_lines "$acc")
EOF
  echo "$out"
}

# True if the AC (line) is satisfied: non-test -> inline flag; else a green AT.
ac_is_satisfied() {
  local line="$1" acc="$2" id atline
  if ac_is_nontest "$line"; then
    [ "$(ac_flag "$line")" = "yes" ]
    return
  fi
  id="$(line_id "$line")"
  while IFS= read -r atline; do
    [ -z "$atline" ] && continue
    case " $(at_covers "$atline") " in
      *" $id "*)
        [ "$(at_status "$atline")" = "green" ] && return 0
        ;;
    esac
  done <<EOF
$(at_lines "$acc")
EOF
  return 1
}

# ---- in-place edit (linter-stable: rewrites only the matched line) -------

replace_line() {
  local f="$1" expr="$2" tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/intent_acc.XXXXXX")" || error "cannot create temp file"
  if sed -E "$expr" "$f" > "$tmp"; then
    cat "$tmp" > "$f"
    rm -f "$tmp"
  else
    rm -f "$tmp"
    error "in-place edit failed for $f"
  fi
}

# ---- commands ------------------------------------------------------------

cmd_ac_list() {
  [ -n "$1" ] || usage
  resolve_or_die "$1"
  local acc line id ats sat
  acc="$(acc_file)"
  warn_malformed "$acc"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    id="$(line_id "$line")"
    in_wp_filter "$id" || continue
    ats="$(ac_covering_ats "$id" "$acc")"
    [ -z "$ats" ] && ats=" -"
    if ac_is_satisfied "$line" "$acc"; then sat="yes"; else sat="no"; fi
    printf 'ac: %s  covered-by:%s  satisfied: %s\n' "$id" "$ats" "$sat"
  done <<EOF
$(ac_lines "$acc")
EOF
}

cmd_ac_status() {
  [ -n "$1" ] || usage
  resolve_or_die "$1"
  local acc line total=0 sat=0 verdict="BLOCKED"
  acc="$(acc_file)"
  warn_malformed "$acc"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    in_wp_filter "$(line_id "$line")" || continue
    total=$((total + 1))
    if ac_is_satisfied "$line" "$acc"; then sat=$((sat + 1)); fi
  done <<EOF
$(ac_lines "$acc")
EOF
  [ "$total" -gt 0 ] && [ "$sat" -eq "$total" ] && verdict="PASS"
  echo "ac: $sat/$total satisfied -- $verdict"
}

# Close-gate (ST0044 WP-04; hardened ST0048). The single authority `st done` /
# `wp done` consult before closing. It REFUSES (exit 1 + a BLOCKED report) when
# the in-scope contract is not verifiably done:
#   - no `acceptance.md` at all (no contract);
#   - a present `acceptance.md` with zero acceptance criteria (empty contract);
#   - malformed AC/AT lines (F1);
#   - an in-scope AC unsatisfied.
#   - a scope that does not resolve to a real ST or WP (issue 0004).
# The sole escape is an explicit, visible `acceptance: exempt` in the frontmatter
# (the gate prints an EXEMPT line -- No Silent Errors; an exemption is announced,
# never inferred from emptiness). Default = enforced.
#
# EVERY exit path reports what it evaluated -- PASS/EXEMPT/BLOCKED (issue 0004).
# Silence used to be the gate's success signal, which is what hid the vacuous
# passes: an unresolvable scope evaluated nothing and exited 0 indistinguishably
# from a contract verified in full. A gate that cannot say what it checked
# cannot be trusted when it says nothing is wrong.
#
# WP scope (`<st>/NN`) stays WP-lenient -- a WP with no own ACs rolls up to the
# ST boundary as long as the thread carries a contract -- but the rollup is now
# granted only to a WP that EXISTS, and is announced when taken. A typo'd
# `<st>/99` matches no ACs for the same arithmetic reason a real AC-free WP
# does; only a directory probe tells the two apart.
cmd_ac_gate() {
  [ -n "$1" ] || usage
  local scope="$1"
  # Same resolver as every reader command; only the presentation differs -- the
  # gate speaks BLOCKED (it is read by machines via $?), the readers use error().
  local id dir acc
  if ! resolve_target "$scope"; then
    echo "gate: $scope BLOCKED -- $TARGET_REASON (nothing to evaluate)"
    exit 1
  fi
  id="$ST_ID"
  dir="$TARGET_DIR"
  acc="$dir/acceptance.md"
  if [ ! -f "$acc" ]; then
    echo "gate: $scope BLOCKED -- no acceptance.md (no contract). Author ACs in acceptance.md, or add 'acceptance: exempt' to its frontmatter."
    exit 1
  fi
  local exval
  exval="$(acceptance_field "$acc")"
  case "$exval" in
    exempt*)
      echo "gate: $scope EXEMPT -- acceptance.md declares 'acceptance: $exval'"
      exit 0
      ;;
  esac
  if ! warn_malformed "$acc"; then
    echo "gate: $scope BLOCKED -- malformed AC/AT line(s) in acceptance.md (see warnings); fix the contract"
    exit 1
  fi
  local line lid total=0 sat=0 unsat="" thread_total=0
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    thread_total=$((thread_total + 1))
    lid="$(line_id "$line")"
    in_wp_filter "$lid" || continue
    total=$((total + 1))
    if ac_is_satisfied "$line" "$acc"; then
      sat=$((sat + 1))
    else
      unsat="$unsat $lid"
    fi
  done <<EOF
$(ac_lines "$acc")
EOF
  if [ "$thread_total" -eq 0 ]; then
    echo "gate: $scope BLOCKED -- acceptance.md has zero acceptance criteria (empty contract). Define ACs, or mark 'acceptance: exempt' in the frontmatter."
    exit 1
  fi
  if [ "$total" -eq 0 ]; then
    # The WP exists (probed above) but carries no ACs of its own: the ST0044
    # WP-lenient rollup. Announced, not inferred -- same contract as EXEMPT.
    echo "gate: $scope PASS -- no ACs in scope; rolls up to the $id contract ($thread_total AC(s))"
    exit 0
  fi
  if [ "$sat" -eq "$total" ]; then
    echo "gate: $scope PASS -- $sat/$total satisfied"
    exit 0
  fi
  echo "gate: $scope BLOCKED -- $sat/$total satisfied; unsatisfied:${unsat}"
  exit 1
}

cmd_ac_satisfy() {
  local stid="$1" acid="$2"
  shift 2 2>/dev/null || usage
  local ref=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --evidence)   ref="$2"; shift 2 ;;
      --evidence=*) ref="${1#--evidence=}"; shift ;;
      *)            shift ;;
    esac
  done
  [ -n "$stid" ] && [ -n "$acid" ] || usage
  local acc line
  resolve_or_die "$stid"
  acc="$(acc_file)"
  line="$(find_line "$acid" "$acc")"
  [ -n "$line" ] || error "no such AC: $acid in $acc"
  ac_is_nontest "$line" || error "$acid is test-backed; satisfaction is computed from a green covering AT, cannot be hand-satisfied"
  [ -n "$ref" ] || error "ac satisfy requires --evidence \"<ref>\""
  local esc ref_esc
  esc="$(echo "$acid" | sed 's/\./\\./g')"
  ref_esc="$(printf '%s' "$ref" | sed -e 's/[&|\\]/\\&/g')"
  replace_line "$acc" "s|^(- ${esc} .*) -- evidence:.*|\1 -- evidence: ${ref_esc} -- satisfied: yes|"
  echo "ok: $acid satisfied by evidence"
}

cmd_at_list() {
  [ -n "$1" ] || usage
  resolve_or_die "$1"
  local acc line id
  acc="$(acc_file)"
  warn_malformed "$acc"
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    id="$(line_id "$line")"
    in_wp_filter "$id" || continue
    printf 'at: %s  %s  %s\n' "$id" "$(at_pathname "$line")" "$(at_status "$line")"
  done <<EOF
$(at_lines "$acc")
EOF
}

cmd_at_set() {
  local target="$1" stid="$2" atid="$3"
  [ "$target" = "na" ] && target="n/a"
  [ -n "$stid" ] && [ -n "$atid" ] || usage
  local acc line cur esc
  resolve_or_die "$stid"
  acc="$(acc_file)"
  line="$(find_line "$atid" "$acc")"
  [ -n "$line" ] || error "no such AT: $atid in $acc"
  cur="$(at_status "$line")"
  if [ "$target" = "green" ] && [ "$cur" != "red" ]; then
    error "at green: $atid is '$cur'; green is reachable only from red (run 'intent at red $stid $atid' first)"
  fi
  esc="$(echo "$atid" | sed 's/\./\\./g')"
  replace_line "$acc" "s|^(- ${esc} .*) -- status:.*|\1 -- status: ${target}|"
  echo "ok: $atid -> $target"
}

# ---- dispatch ------------------------------------------------------------

NOUN="$1"
shift 2>/dev/null || usage
[ $# -ge 1 ] || usage
VERB="$1"
shift

case "$NOUN" in
  ac)
    case "$VERB" in
      list)    cmd_ac_list "$@" ;;
      status)  cmd_ac_status "$@" ;;
      satisfy) cmd_ac_satisfy "$@" ;;
      gate)    cmd_ac_gate "$@" ;;
      *)       error "unknown ac command: $VERB (try: list, status, satisfy, gate)" ;;
    esac
    ;;
  at)
    case "$VERB" in
      list)         cmd_at_list "$@" ;;
      red|green|na) cmd_at_set "$VERB" "$@" ;;
      done)         cmd_at_set green "$@" ;;
      notdone)      cmd_at_set red "$@" ;;
      *)            error "unknown at command: $VERB (try: list, red, green, na, done, notdone)" ;;
    esac
    ;;
  *)
    usage
    ;;
esac
