#!/bin/bash
# intent_claude_upgrade - Upgrade LLM guidance layer for Intent projects
# Copyright (c) 2026 Matthew Sinclair
# Licensed under the MIT License (see LICENSE file)
# Usage: intent claude upgrade [--apply] [--project-dir DIR]
#
# Dry-run by default. Shows what changes would be made.
# Use --apply to actually execute the changes.
#
# Note: `set -e` deferred (see WP12 dogfood Entry 1) -- diagnostic checks
# return non-zero to signal "needs upgrade"; strict mode would abort
# instead of reporting.

# Source helpers from main bin directory
PLUGIN_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INTENT_ROOT="$(cd "$PLUGIN_BIN/../../../.." && pwd)"
INTENT_BIN="$INTENT_ROOT/bin"
source "$INTENT_BIN/intent_helpers"

# Configuration
SKILLS_SOURCE="$INTENT_ROOT/intent/plugins/claude/skills"
SUBAGENTS_SOURCE="$INTENT_ROOT/intent/plugins/claude/subagents"
# TEMPLATES_SOURCE is set per-project below once the project's primary
# language is detected. Falls back to _default/ for languages without a
# specific template directory.
TEMPLATES_SOURCE=""

# Canon template paths (ST0035 / v2.10.0). Each artefact ships through the
# --apply path; probes in Phase 1 enqueue installs when the target is absent
# or diverges from the canon template.
CANON_SETTINGS_SRC="$INTENT_ROOT/lib/templates/.claude/settings.json"
CANON_SCRIPTS_SRC="$INTENT_ROOT/lib/templates/.claude/scripts"
CANON_PRE_COMMIT_SRC="$INTENT_ROOT/lib/templates/hooks/pre-commit.sh"
CANON_CRITIC_YML_SRC="$INTENT_ROOT/lib/templates/_intent_critic.yml"
CANON_CLAUDE_MD_SRC="$INTENT_ROOT/lib/templates/llm/_CLAUDE.md"
CANON_USAGE_RULES_SRC="$INTENT_ROOT/lib/templates/llm/_usage-rules.md"
CANON_MODULES_SRC="$INTENT_ROOT/lib/templates/llm/_MODULES.md"
CANON_DECISION_TREE_SRC="$INTENT_ROOT/lib/templates/llm/_DECISION_TREE.md"
CANON_TREEINDEXIGNORE_SRC="$INTENT_ROOT/lib/templates/_treeindexignore"

# Canon user-section preservation markers (keep in sync with _CLAUDE.md).
CANON_USER_MARK_START="<!-- user:start -->"
CANON_USER_MARK_END="<!-- user:end -->"
CANON_INTENT_FOOTER_MARK="Generated from \`lib/templates/llm/_CLAUDE.md\`"

# Read target version from VERSION file (single source of truth)
TARGET_VERSION="$(cat "$INTENT_ROOT/VERSION" 2>/dev/null | tr -d '[:space:]')"
if [ -z "$TARGET_VERSION" ]; then
  echo "Error: Cannot read VERSION file at $INTENT_ROOT/VERSION"
  exit 1
fi

# Show help
intent_claude_upgrade_help() {
  cat << EOF
Usage: intent claude upgrade [options]

Diagnose and upgrade the LLM guidance layer of an Intent project.

This command is DRY-RUN by default. It shows what changes would be made
without modifying anything. Use --apply to execute the changes.

Options:
  --apply              Execute the upgrade (default is dry-run)
  --project-dir DIR    Target project directory (default: current directory)
  --force              Overwrite user-edited canon files (CLAUDE.md without
                       the Intent footer marker, .intent_critic.yml,
                       usage-rules.md). Destructive; pair with --dry-run first.
  --skip-settings      Skip .claude/settings.json + 3 hook scripts. Useful for
                       projects with deeply customised settings that do not
                       fit the marker-preservation pattern.
  -h, --help           Show this help

The upgrade covers:
  - Version bump (intent/.config/config.json intent_version to $TARGET_VERSION)
  - Subagent updates (all installed subagents synced to latest)
  - Skill updates (all installed skills synced to latest)
  - LLM guidance files (AGENTS.md, RULES.md, ARCHITECTURE.md)
  - Canon artefacts (.claude/settings.json + scripts, .git/hooks/pre-commit,
    .intent_critic.yml, root CLAUDE.md, root usage-rules.md, intent/llm seeds,
    intent/.treeindex/.treeindexignore)
  - Deprecated file cleanup (llm_preamble.md, old usage-rules.md, intent-* skills)

Examples:
  intent claude upgrade                           # Dry-run on current project
  intent claude upgrade --apply                    # Apply changes
  intent claude upgrade --project-dir ~/prolix     # Diagnose another project
  intent claude upgrade --project-dir ~/prolix --apply  # Upgrade another project
  intent claude upgrade --apply --skip-settings    # Skip the .claude/ stack
  intent claude upgrade --apply --force            # Overwrite user-edited canon
EOF
}

# Parse arguments
DRY_RUN=true
PROJECT_DIR=""
FORCE=false
SKIP_SETTINGS=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --apply)
      DRY_RUN=false
      shift
      ;;
    --project-dir)
      PROJECT_DIR="$2"
      shift 2
      ;;
    --force)
      FORCE=true
      shift
      ;;
    --skip-settings)
      SKIP_SETTINGS=true
      shift
      ;;
    -h|--help)
      intent_claude_upgrade_help
      exit 0
      ;;
    *)
      echo "Error: Unknown option '$1'"
      intent_claude_upgrade_help
      exit 1
      ;;
  esac
done

# Determine project directory
if [ -z "$PROJECT_DIR" ]; then
  if [ -n "${PROJECT_ROOT:-}" ]; then
    PROJECT_DIR="$PROJECT_ROOT"
  else
    PROJECT_DIR="$(pwd)"
  fi
fi

# Validate it's an Intent project
if [ ! -d "$PROJECT_DIR/intent" ]; then
  echo "Error: '$PROJECT_DIR' does not appear to be an Intent project"
  echo "  (no intent/ directory found)"
  exit 1
fi

# Resolve PROJECT_DIR to an absolute path so basename and template probes
# don't trip on relative paths (`basename "."` returns "." which would
# render as `# .` in the regenerated CLAUDE.md title).
PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
  echo "Error: Cannot resolve project directory '$PROJECT_DIR' to an absolute path"
  exit 1
}

# Prefer the canonical project_name from intent/.config/config.json (user-set
# at `intent init` time and stable across directory renames). Fall back to
# basename of the absolute path when config.json is unavailable.
PROJECT_NAME=""
if [ -f "$PROJECT_DIR/intent/.config/config.json" ] && command -v jq >/dev/null 2>&1; then
  PROJECT_NAME=$(jq -r '.project_name // empty' "$PROJECT_DIR/intent/.config/config.json" 2>/dev/null)
fi
[ -z "$PROJECT_NAME" ] && PROJECT_NAME="$(basename "$PROJECT_DIR")"

# RULES.md / ARCHITECTURE.md / AGENTS.md are installed from the language-
# agnostic _default/ templates. Most real-world projects are polyglot
# (Elixir + Rust + Lua + bash + HTML/CSS/JS content), so picking any single
# "primary language" template would be wrong-shaped for the majority. The
# _default templates point at the rule library at intent/plugins/claude/rules/
# generically; project-specific content goes in the user-section of CLAUDE.md
# or in language pointers added to RULES.md by the project author.
#
# The language-specific templates (templates/elixir/, etc.) remain as opt-in
# starters that `intent init --template <lang>` can use; canon-installer
# never auto-picks them.
TEMPLATES_SOURCE="$INTENT_ROOT/intent/plugins/agents/templates/_default"

# Writability probe -- bail with a clear error before doing any work if the
# filesystem is read-only. Dry-run never writes, so this only matters on apply.
if [ "$DRY_RUN" = false ]; then
  _writable_probe="$(mktemp "$PROJECT_DIR/.intent_writable_probe.XXXXXX" 2>/dev/null)"
  if [ -z "$_writable_probe" ] || [ ! -f "$_writable_probe" ]; then
    echo "Error: '$PROJECT_DIR' is not writable (read-only filesystem?)"
    echo "  Re-run from a writable copy of the project, or fix permissions."
    exit 1
  fi
  rm -f "$_writable_probe"
fi

# Color codes (if terminal)
if [ -t 1 ]; then
  RED='\033[0;31m'
  YELLOW='\033[0;33m'
  GREEN='\033[0;32m'
  BLUE='\033[0;34m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  RED=''
  YELLOW=''
  GREEN=''
  BLUE=''
  BOLD=''
  NC=''
fi

# Action tracking
declare -a ACTIONS=()
declare -a WARNINGS=()

add_action() {
  ACTIONS+=("$1")
}

add_warning() {
  WARNINGS+=("$1")
}

# ============================================================
# Canon-install helpers (ST0035/WP-11)
# ============================================================
#
# These helpers are invoked in Phase 3 (--apply). Each returns 0 on success
# and a non-zero on recoverable failure; the caller surfaces the diagnostic.
# Fail-forward: one artefact's failure does not roll back others.

# Substitute the canon placeholders in $1 in-place.
# Expects PROJECT_NAME, CANON_AUTHOR, CANON_DATE, TARGET_VERSION, INTENT_ROOT
# in scope.
canon_substitute_placeholders() {
  local file="$1"
  # Use | as sed delimiter for INTENT_HOME to tolerate / in paths.
  sed -i '' \
    -e "s/\[\[PROJECT_NAME\]\]/$PROJECT_NAME/g" \
    -e "s/\[\[AUTHOR\]\]/$CANON_AUTHOR/g" \
    -e "s/\[\[DATE\]\]/$CANON_DATE/g" \
    -e "s/\[\[INTENT_VERSION\]\]/$TARGET_VERSION/g" \
    -e "s|\[\[INTENT_HOME\]\]|$INTENT_ROOT|g" \
    "$file"
}

# Copy $src -> $dst. Parent dir created if absent. Placeholder-substituted.
canon_install_file() {
  local src="$1"
  local dst="$2"
  mkdir -p "$(dirname "$dst")"
  cp "$src" "$dst"
  canon_substitute_placeholders "$dst"
}

# Copy $src -> $dst, then chmod +x. Placeholder-substituted.
canon_install_script() {
  local src="$1"
  local dst="$2"
  canon_install_file "$src" "$dst"
  chmod +x "$dst"
}

# Remove $path if it exists. No error if absent (idempotent).
canon_delete_file() {
  local path="$1"
  [ -e "$path" ] && rm -f "$path"
  return 0
}

# Extract content between CANON_USER_MARK_START / CANON_USER_MARK_END in $1.
# Emits (exclusive of the markers) to stdout. Empty output if markers absent.
canon_extract_user_section() {
  local file="$1"
  [ -f "$file" ] || return 0
  awk -v s="$CANON_USER_MARK_START" -v e="$CANON_USER_MARK_END" '
    index($0, s) { cap = 1; next }
    index($0, e) { cap = 0; next }
    cap { print }
  ' "$file"
}

# Refresh $dst from canon template $src, preserving any user-section content
# already present in $dst (between the HTML-comment markers). If no markers
# in existing $dst, behaves like canon_install_file (clean overwrite). When
# --force is set, the preserve step is skipped and $dst is clean-overwritten.
canon_refresh_with_user_section() {
  local src="$1"
  local dst="$2"

  if [ "$FORCE" = true ]; then
    canon_install_file "$src" "$dst"
    return 0
  fi

  local preserved
  preserved="$(canon_extract_user_section "$dst")"

  # Fresh install path -- no existing user content to preserve.
  if [ -z "$preserved" ] || ! grep -qF "$CANON_USER_MARK_START" "$dst" 2>/dev/null; then
    canon_install_file "$src" "$dst"
    return 0
  fi

  local out
  out="$(mktemp)"
  canon_compute_refresh_preview "$src" "$dst" "$out"
  mv "$out" "$dst"
}

# Compute what $dst would look like after a refresh from $src that preserves
# its user section (between the HTML-comment markers). Writes the result to
# $out_path. Used by both Phase 1 (drift probe) and Phase 2 (dry-run diff).
#
# The preserved user content is staged in a temp file (not a shell variable)
# so trailing blank lines round-trip exactly. Command substitution strips
# trailing newlines, which would corrupt the round-trip and report bogus
# drift on every re-run.
canon_compute_refresh_preview() {
  local src="$1"
  local dst="$2"
  local out_path="$3"

  local tmp preserved_file
  tmp="$(mktemp)"
  preserved_file="$(mktemp)"
  cp "$src" "$tmp"
  canon_substitute_placeholders "$tmp"

  if [ -f "$dst" ] && grep -qF "$CANON_USER_MARK_START" "$dst" 2>/dev/null; then
    canon_extract_user_section "$dst" > "$preserved_file"
  fi

  awk -v s="$CANON_USER_MARK_START" -v e="$CANON_USER_MARK_END" -v pf="$preserved_file" '
    index($0, s) {
      print
      in_user = 1
      while ((getline line < pf) > 0) print line
      close(pf)
      next
    }
    index($0, e) { in_user = 0; print; next }
    !in_user { print }
  ' "$tmp" > "$out_path"

  rm -f "$tmp" "$preserved_file"
}

# Probe whether two files are byte-identical. 0 = identical, 1 = differ or
# either missing. Uses `cmp -s` (present on every POSIX system we target).
canon_files_identical() {
  cmp -s "$1" "$2" 2>/dev/null
}

# Compare an on-disk canon file against a template, accounting for
# placeholder substitution. Returns 0 if the installed file matches a
# freshly-substituted template (i.e. no install needed).
canon_template_matches_installed() {
  local src="$1"
  local dst="$2"
  [ -f "$dst" ] || return 1
  local tmp
  tmp="$(mktemp)"
  cp "$src" "$tmp"
  canon_substitute_placeholders "$tmp"
  if canon_files_identical "$tmp" "$dst"; then
    rm -f "$tmp"
    return 0
  fi
  rm -f "$tmp"
  return 1
}

# Check whether the destination CLAUDE.md carries the Intent-generated footer
# marker. A user-authored CLAUDE.md without the marker is left alone.
canon_claude_md_is_generated() {
  local dst="$1"
  [ -f "$dst" ] && grep -qF "$CANON_INTENT_FOOTER_MARK" "$dst" 2>/dev/null
}

# Resolve author for placeholder substitution. Preference: intent/.config/config.json
# author field -> $INTENT_AUTHOR -> $USER -> "Unknown".
canon_resolve_author() {
  local cfg="$PROJECT_DIR/intent/.config/config.json"
  local author=""
  if [ -f "$cfg" ] && command -v jq >/dev/null 2>&1; then
    author="$(jq -r '.author // ""' "$cfg" 2>/dev/null)"
  fi
  [ -z "$author" ] && author="${INTENT_AUTHOR:-${USER:-Unknown}}"
  echo "$author"
}

# Resolve the actual git hooks directory for $1. Returns 0 with the absolute
# path on stdout when the project is a git repo (including worktrees and
# submodules where .git is a file gitlink). Returns 1 with no output when
# git is unavailable, $1 is not a repo, or rev-parse fails.
canon_hooks_dir() {
  local proj="$1"
  command -v git >/dev/null 2>&1 || return 1
  [ -e "$proj/.git" ] || return 1
  local hooks
  hooks="$(cd "$proj" && git rev-parse --git-path hooks 2>/dev/null)" || return 1
  [ -n "$hooks" ] || return 1
  case "$hooks" in
    /*) ;;
    *) hooks="$proj/$hooks" ;;
  esac
  echo "$hooks"
}

# Chain block markers used to make insertion idempotent. The block invokes
# .git/hooks/pre-commit.intent (the canon critic gate) so a project with a
# pre-existing pre-commit hook can keep its own logic alongside the gate.
CANON_CHAIN_START="# intent-chain-block:start (generated by intent claude upgrade)"
CANON_CHAIN_END="# intent-chain-block:end"

# Returns 0 if $1 contains the chain block markers, 1 otherwise.
canon_chain_block_present() {
  local target="$1"
  [ -f "$target" ] || return 1
  grep -qF "intent-chain-block:start" "$target" 2>/dev/null
}

# Emit the chain block (with markers) to stdout. Used by canon_insert_chain_block
# both for first insertion and for the empty-file fallback.
canon_emit_chain_block() {
  cat <<CHAIN
$CANON_CHAIN_START
_intent_chain="\$(git rev-parse --git-path hooks 2>/dev/null)/pre-commit.intent"
if [ -x "\$_intent_chain" ]; then
  "\$_intent_chain" "\$@" || exit \$?
fi
$CANON_CHAIN_END
CHAIN
}

# Insert the chain block into $1 idempotently. If markers are already present,
# do nothing. Otherwise insert the block immediately after the hook's preamble
# (shebang + leading `set -*` / blank / comment lines) so it runs as the first
# real command under the same shell discipline as the rest of the hook.
canon_insert_chain_block() {
  local target="$1"
  if canon_chain_block_present "$target"; then
    return 0
  fi

  local tmp
  tmp="$(mktemp)"

  local in_preamble=1
  local inserted=0
  local line

  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$in_preamble" -eq 1 ]; then
      case "$line" in
        '#!'*|'')              printf '%s\n' "$line" >> "$tmp"; continue ;;
        'set -'*|'set +'*)     printf '%s\n' "$line" >> "$tmp"; continue ;;
        *)
          in_preamble=0
          canon_emit_chain_block >> "$tmp"
          printf '\n' >> "$tmp"
          inserted=1
          ;;
      esac
    fi
    printf '%s\n' "$line" >> "$tmp"
  done < "$target"

  if [ "$inserted" -eq 0 ]; then
    if [ ! -s "$tmp" ]; then
      printf '#!/usr/bin/env bash\n' >> "$tmp"
    fi
    printf '\n' >> "$tmp"
    canon_emit_chain_block >> "$tmp"
  fi

  cat "$tmp" > "$target"
  rm -f "$tmp"
  chmod +x "$target"
}

# Returns 0 if .gitignore at $1 has any of the canon-managed entries missing
# or in a non-canonical form (broad .claude pattern, missing settings.local
# ignore, missing AGENTS.md.bak ignore). Returns 1 if the file is fully
# canonical (or absent -- nothing to normalize).
canon_gitignore_needs_normalize() {
  local gi="$1"
  [ -f "$gi" ] || return 1
  # Broad .claude pattern (whole directory ignore).
  grep -qE '^[[:space:]]*\.claude/?[[:space:]]*$' "$gi" 2>/dev/null && return 0
  # Missing canonical .claude/settings.local.json ignore.
  grep -qE '^[[:space:]]*\.claude/settings\.local\.json[[:space:]]*$' "$gi" 2>/dev/null || return 0
  # Missing /AGENTS.md.bak ignore.
  grep -qE '^[[:space:]]*/?AGENTS\.md\.bak[[:space:]]*$' "$gi" 2>/dev/null || return 0
  return 1
}

# Normalize .gitignore at $1: replace broad .claude/ pattern with the
# canonical .claude/settings.local.json line; append .claude/settings.local.json
# if missing; append /AGENTS.md.bak if missing. Idempotent.
canon_normalize_gitignore() {
  local gi="$1"
  [ -f "$gi" ] || return 0

  # Replace broad .claude (or .claude/) standalone line with the canonical form.
  if grep -qE '^[[:space:]]*\.claude/?[[:space:]]*$' "$gi" 2>/dev/null; then
    local tmp
    tmp="$(mktemp)"
    awk '/^[[:space:]]*\.claude\/?[[:space:]]*$/ { print ".claude/settings.local.json"; next } { print }' "$gi" > "$tmp"
    cat "$tmp" > "$gi"
    rm -f "$tmp"
  fi

  # Append canonical .claude/settings.local.json if not present.
  if ! grep -qE '^[[:space:]]*\.claude/settings\.local\.json[[:space:]]*$' "$gi" 2>/dev/null; then
    {
      echo ""
      echo "# Per-developer Claude Code settings (paths and tool allowlists vary)."
      echo ".claude/settings.local.json"
    } >> "$gi"
  fi

  # Append /AGENTS.md.bak if not present.
  if ! grep -qE '^[[:space:]]*/?AGENTS\.md\.bak[[:space:]]*$' "$gi" 2>/dev/null; then
    {
      echo ""
      echo "# AGENTS.md regeneration safety net (intent agents sync writes this; transient)."
      echo "/AGENTS.md.bak"
    } >> "$gi"
  fi
}

CANON_AUTHOR="$(canon_resolve_author)"
CANON_DATE="$(date '+%Y-%m-%d')"

# Resolved at Phase 1; used in Phase 2 hints + Phase 3 execute. Empty when
# the project has no .git (worktree-aware via git rev-parse).
PRE_COMMIT_HOOKS_DIR=""
PRE_COMMIT_PATH=""
PRE_COMMIT_INTENT_PATH=""

# Print a canon-artefact diagnostic line with consistent alignment. The status
# column lands at col 43 regardless of label length (longest label needs 41
# chars, so leaving one space minimum). $1 = label (no leading indent / colon),
# $2 = pre-coloured status string (e.g. "${GREEN}UP TO DATE${NC}").
canon_print() {
  local label="$1"
  local status_styled="$2"
  local target=42
  local len=${#label}
  local pad=$((target - 3 - len))
  [ "$pad" -lt 1 ] && pad=1
  echo -e "  $label:$(printf '%*s' "$pad" '')$status_styled"
}

# ============================================================
# PHASE 1: DIAGNOSE
# ============================================================

echo ""
echo -e "${BOLD}Intent LLM Guidance Upgrade -- $PROJECT_NAME${NC}"
echo -e "${BOLD}$(printf '%.0s-' {1..60})${NC}"
if [ "$DRY_RUN" = true ]; then
  echo -e "${YELLOW}Mode: DRY-RUN (use --apply to execute)${NC}"
else
  echo -e "${GREEN}Mode: APPLY${NC}"
fi
if [ "$FORCE" = true ]; then
  echo -e "${RED}--force: user-edited canon files WILL BE OVERWRITTEN.${NC}"
fi
if [ "$SKIP_SETTINGS" = true ]; then
  echo -e "${YELLOW}--skip-settings: .claude/settings.json + hook scripts will be skipped.${NC}"
fi
echo ""

echo -e "${BOLD}Phase 1: Diagnosis${NC}"
echo ""

# Check config version
echo "Checking version..."
if [ -f "$PROJECT_DIR/intent/.config/config.json" ]; then
  current_version=$(grep '"intent_version"' "$PROJECT_DIR/intent/.config/config.json" 2>/dev/null | sed 's/.*: *"\([^"]*\)".*/\1/')
  if [ "$current_version" = "$TARGET_VERSION" ]; then
    echo -e "  intent_version:     ${GREEN}$current_version (current)${NC}"
  else
    echo -e "  intent_version:     ${YELLOW}$current_version -> $TARGET_VERSION${NC}"
    add_action "VERSION_BUMP:$current_version:$TARGET_VERSION"
  fi
else
  echo -e "  config.json:        ${RED}MISSING${NC}"
  add_warning "No intent/.config/config.json found -- cannot update version"
fi

# Check LLM guidance files
echo ""
echo "Checking LLM guidance files..."

# AGENTS.md (canonical location: project root, since v2.10.0 -- see ST0035/WP08).
if [ -f "$PROJECT_DIR/AGENTS.md" ]; then
  local_version=$(grep -o 'intent_version: [0-9][0-9.]*' "$PROJECT_DIR/AGENTS.md" 2>/dev/null | head -1 | cut -d' ' -f2)
  if [ -z "$local_version" ]; then
    local_version=$(grep -o 'v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*' "$PROJECT_DIR/AGENTS.md" 2>/dev/null | head -1 | sed 's/^v//')
  fi
  if [ "$local_version" = "$TARGET_VERSION" ]; then
    echo -e "  AGENTS.md:          ${GREEN}UP TO DATE${NC} (version: $local_version)"
  else
    echo -e "  AGENTS.md:          ${YELLOW}EXISTS${NC} (version: ${local_version:-unknown})"
    add_action "REGENERATE AGENTS.md (currently ${local_version:-unknown}, target $TARGET_VERSION)"
  fi
else
  echo -e "  AGENTS.md:          ${RED}MISSING${NC}"
  add_action "CREATE AGENTS.md from _default template"
fi

# RULES.md
if [ -f "$PROJECT_DIR/intent/llm/RULES.md" ]; then
  rule_count=$(grep -Ec '^(###|[0-9]+\.)' "$PROJECT_DIR/intent/llm/RULES.md" 2>/dev/null)
  [ -z "$rule_count" ] && rule_count=0
  echo -e "  RULES.md:           ${GREEN}EXISTS${NC} ($rule_count rules/sections)"
  if [ -f "$TEMPLATES_SOURCE/RULES.md" ] && cmp -s "$PROJECT_DIR/intent/llm/RULES.md" "$TEMPLATES_SOURCE/RULES.md"; then
    add_warning "REVIEW intent/llm/RULES.md (still verbatim _default template; customise for this project)"
  fi
else
  echo -e "  RULES.md:           ${RED}MISSING${NC}"
  add_action "CREATE intent/llm/RULES.md from _default template"
fi

# ARCHITECTURE.md
if [ -f "$PROJECT_DIR/intent/llm/ARCHITECTURE.md" ]; then
  echo -e "  ARCHITECTURE.md:    ${GREEN}EXISTS${NC}"
  if [ -f "$TEMPLATES_SOURCE/ARCHITECTURE.md" ] && cmp -s "$PROJECT_DIR/intent/llm/ARCHITECTURE.md" "$TEMPLATES_SOURCE/ARCHITECTURE.md"; then
    add_warning "REVIEW intent/llm/ARCHITECTURE.md (still verbatim _default template; customise for this project)"
  fi
else
  echo -e "  ARCHITECTURE.md:    ${RED}MISSING${NC}"
  add_action "CREATE intent/llm/ARCHITECTURE.md from _default template"
fi

# Deprecated files
echo ""
echo "Checking for deprecated files..."

if [ -f "$PROJECT_DIR/intent/llm/AGENTS-phx.md" ]; then
  echo -e "  AGENTS-phx.md:      ${YELLOW}DEPRECATED${NC}"
  add_action "MERGE intent/llm/AGENTS-phx.md Phoenix rules into RULES.md"
  add_action "DELETE intent/llm/AGENTS-phx.md (after merge)"
else
  echo -e "  AGENTS-phx.md:      ${GREEN}not present${NC}"
fi

if [ -f "$PROJECT_DIR/intent/llm/llm_preamble.md" ]; then
  echo -e "  llm_preamble.md:    ${YELLOW}DEPRECATED${NC}"
  add_action "DELETE intent/llm/llm_preamble.md"
else
  echo -e "  llm_preamble.md:    ${GREEN}not present${NC}"
fi

if [ -f "$PROJECT_DIR/intent/llm/usage-rules.md" ]; then
  echo -e "  usage-rules.md:     ${YELLOW}DEPRECATED${NC} (replaced by skills)"
  add_action "DELETE intent/llm/usage-rules.md"
else
  echo -e "  usage-rules.md:     ${GREEN}not present${NC}"
fi

# Check for old-style skill names (intent-* instead of in-*)
echo ""
echo "Checking for deprecated skill names..."
old_skill_found=false
for old_skill_dir in "$HOME/.claude/skills"/intent-*; do
  if [ -d "$old_skill_dir" ]; then
    old_skill_name="$(basename "$old_skill_dir")"
    # Convert intent-foo to in-foo
    new_skill_name="in-${old_skill_name#intent-}"
    echo -e "  $old_skill_name:$(printf '%*s' $((25 - ${#old_skill_name})) '')${YELLOW}RENAME to $new_skill_name${NC}"
    add_action "RENAME_SKILL:$old_skill_name:$new_skill_name"
    old_skill_found=true
  fi
done
if [ "$old_skill_found" = false ]; then
  echo -e "  ${GREEN}No deprecated skill names found${NC}"
fi

# Check subagents
echo ""
echo "Checking installed subagents..."

for subagent_dir in "$SUBAGENTS_SOURCE"/*/; do
  [ -d "$subagent_dir" ] || continue
  subagent_name="$(basename "$subagent_dir")"
  if [ -f "$HOME/.claude/agents/$subagent_name.md" ]; then
    local_checksum=$(calculate_checksum "$HOME/.claude/agents/$subagent_name.md" 2>/dev/null)
    source_checksum=$(calculate_checksum "$subagent_dir/agent.md" 2>/dev/null)
    if [ "$local_checksum" = "$source_checksum" ] && [ -n "$local_checksum" ] && [ "$local_checksum" != "unknown" ]; then
      echo -e "  $subagent_name:$(printf '%*s' $((20 - ${#subagent_name})) '')${GREEN}UP TO DATE${NC}"
    else
      echo -e "  $subagent_name:$(printf '%*s' $((20 - ${#subagent_name})) '')${YELLOW}OUTDATED${NC}"
      add_action "UPDATE_SUBAGENT:$subagent_name"
    fi
  else
    echo -e "  $subagent_name:$(printf '%*s' $((20 - ${#subagent_name})) '')${BLUE}not installed${NC}"
  fi
done

# Check installed skills against source
echo ""
echo "Checking installed skills..."

for skill_dir in "$HOME/.claude/skills"/in-*/; do
  [ -d "$skill_dir" ] || continue
  skill_name="$(basename "$skill_dir")"
  if [ -d "$SKILLS_SOURCE/$skill_name" ]; then
    local_checksum=$(calculate_checksum "$skill_dir/SKILL.md" 2>/dev/null)
    source_checksum=$(calculate_checksum "$SKILLS_SOURCE/$skill_name/SKILL.md" 2>/dev/null)
    if [ "$local_checksum" = "$source_checksum" ] && [ -n "$local_checksum" ] && [ "$local_checksum" != "unknown" ]; then
      echo -e "  $skill_name:$(printf '%*s' $((25 - ${#skill_name})) '')${GREEN}UP TO DATE${NC}"
    else
      echo -e "  $skill_name:$(printf '%*s' $((25 - ${#skill_name})) '')${YELLOW}OUTDATED${NC}"
      add_action "UPDATE_SKILL:$skill_name"
    fi
  fi
done

# ============================================================
# Canon artefact probes (ST0035/WP-11)
# ============================================================

echo ""
echo "Checking canon artefacts..."

# .claude/settings.json -- hooks for /in-session, /in-finish, UserPromptSubmit.
# .claude/scripts/*.sh -- three hook helper scripts.
# Both blocks gated on --skip-settings (single escape hatch for projects with
# deeply customised settings.json that does not fit the marker pattern).
if [ "$SKIP_SETTINGS" = true ]; then
  canon_print ".claude/settings.json" "${BLUE}skipped (--skip-settings)${NC}"
  canon_print ".claude/scripts/*.sh"  "${BLUE}skipped (--skip-settings)${NC}"
else
  if [ -f "$PROJECT_DIR/.claude/settings.json" ]; then
    if canon_template_matches_installed "$CANON_SETTINGS_SRC" "$PROJECT_DIR/.claude/settings.json"; then
      canon_print ".claude/settings.json" "${GREEN}UP TO DATE${NC}"
    else
      canon_print ".claude/settings.json" "${YELLOW}DIVERGED${NC}"
      add_action "INSTALL_SETTINGS"
    fi
  else
    canon_print ".claude/settings.json" "${RED}MISSING${NC}"
    add_action "INSTALL_SETTINGS"
  fi

  for _script in session-context.sh require-in-session.sh post-tool-advisory.sh; do
    _src="$CANON_SCRIPTS_SRC/$_script"
    _dst="$PROJECT_DIR/.claude/scripts/$_script"
    _label=".claude/scripts/$_script"
    if [ -f "$_dst" ] && canon_template_matches_installed "$_src" "$_dst"; then
      canon_print "$_label" "${GREEN}UP TO DATE${NC}"
    elif [ -f "$_dst" ]; then
      canon_print "$_label" "${YELLOW}DIVERGED${NC}"
      add_action "INSTALL_HOOK_SCRIPT:$_script"
    else
      canon_print "$_label" "${RED}MISSING${NC}"
      add_action "INSTALL_HOOK_SCRIPT:$_script"
    fi
  done
fi

# .git/hooks/pre-commit -- critic gate. Chain if a pre-existing non-Intent
# hook is present (detect by absence of our canonical banner string). Hook
# path resolved via `git rev-parse --git-path hooks` so worktrees and
# submodules (where .git is a file gitlink) work transparently.
PRE_COMMIT_HOOKS_DIR="$(canon_hooks_dir "$PROJECT_DIR")"
if [ -z "$PRE_COMMIT_HOOKS_DIR" ]; then
  canon_print ".git/hooks/pre-commit" "${BLUE}skipped (no git repo)${NC}"
else
  PRE_COMMIT_PATH="$PRE_COMMIT_HOOKS_DIR/pre-commit"
  PRE_COMMIT_INTENT_PATH="$PRE_COMMIT_HOOKS_DIR/pre-commit.intent"
  if [ -f "$PRE_COMMIT_PATH" ]; then
    if grep -qF "intent critic gate" "$PRE_COMMIT_PATH" 2>/dev/null; then
      if canon_files_identical "$CANON_PRE_COMMIT_SRC" "$PRE_COMMIT_PATH"; then
        canon_print ".git/hooks/pre-commit" "${YELLOW}LEGACY (single-file; migrating to chained)${NC}"
        add_action "MIGRATE_LEGACY_PRE_COMMIT"
      else
        canon_print ".git/hooks/pre-commit" "${YELLOW}DIVERGED${NC}"
        add_action "INSTALL_PRE_COMMIT"
      fi
    else
      if [ -f "$PRE_COMMIT_INTENT_PATH" ] && canon_files_identical "$CANON_PRE_COMMIT_SRC" "$PRE_COMMIT_INTENT_PATH"; then
        if canon_chain_block_present "$PRE_COMMIT_PATH"; then
          canon_print ".git/hooks/pre-commit" "${GREEN}CHAINED${NC} (chain block present)"
        else
          canon_print ".git/hooks/pre-commit" "${YELLOW}CHAIN_REQUIRED${NC} (gate installed; chain block missing)"
          add_action "CHAIN_PRE_COMMIT_BLOCK"
        fi
      else
        canon_print ".git/hooks/pre-commit" "${YELLOW}NON-INTENT HOOK PRESENT${NC}"
        add_action "CHAIN_PRE_COMMIT"
      fi
    fi
  else
    canon_print ".git/hooks/pre-commit" "${RED}MISSING${NC}"
    add_action "INSTALL_PRE_COMMIT"
  fi
fi

# .intent_critic.yml -- install only if absent (user-editable). With --force,
# overwrite even when present (tunings will be lost).
if [ -f "$PROJECT_DIR/.intent_critic.yml" ]; then
  if [ "$FORCE" = true ]; then
    canon_print ".intent_critic.yml" "${RED}OVERWRITE (--force; user tunings lost)${NC}"
    add_action "INSTALL_CRITIC_CONFIG"
  else
    canon_print ".intent_critic.yml" "${GREEN}PRESENT${NC} (user-owned)"
  fi
else
  canon_print ".intent_critic.yml" "${RED}MISSING${NC}"
  add_action "INSTALL_CRITIC_CONFIG"
fi

# Root CLAUDE.md -- install if absent; refresh if Intent-generated (preserve
# user section); leave alone if user-authored (no Intent footer marker)
# unless --force is set.
if [ -f "$PROJECT_DIR/CLAUDE.md" ]; then
  if canon_claude_md_is_generated "$PROJECT_DIR/CLAUDE.md"; then
    _tmp_refresh_preview="$(mktemp)"
    canon_compute_refresh_preview "$CANON_CLAUDE_MD_SRC" "$PROJECT_DIR/CLAUDE.md" "$_tmp_refresh_preview"
    if canon_files_identical "$PROJECT_DIR/CLAUDE.md" "$_tmp_refresh_preview"; then
      canon_print "CLAUDE.md (root)" "${GREEN}UP TO DATE${NC}"
    else
      canon_print "CLAUDE.md (root)" "${YELLOW}REFRESH (user section preserved)${NC}"
      add_action "REFRESH_CLAUDE_MD"
    fi
    rm -f "$_tmp_refresh_preview"
  elif [ "$FORCE" = true ]; then
    canon_print "CLAUDE.md (root)" "${RED}OVERWRITE (--force; user-authored content lost)${NC}"
    add_action "INSTALL_CLAUDE_MD"
  else
    canon_print "CLAUDE.md (root)" "${BLUE}user-authored (left alone)${NC}"
    add_warning "CLAUDE.md at root is user-authored (no Intent footer marker); not refreshed. Compare with \`lib/templates/llm/_CLAUDE.md\` if you want to adopt the canon overlay, or re-run with --force to overwrite."
  fi
else
  canon_print "CLAUDE.md (root)" "${RED}MISSING${NC}"
  add_action "INSTALL_CLAUDE_MD"
fi

# Root usage-rules.md -- install only if absent. Users customise freely.
# With --force, overwrite even when present (user content will be lost).
if [ -f "$PROJECT_DIR/usage-rules.md" ]; then
  if [ "$FORCE" = true ]; then
    canon_print "usage-rules.md (root)" "${RED}OVERWRITE (--force; user content lost)${NC}"
    add_action "INSTALL_USAGE_RULES"
  else
    canon_print "usage-rules.md (root)" "${GREEN}PRESENT${NC} (user-owned)"
  fi
else
  canon_print "usage-rules.md (root)" "${RED}MISSING${NC}"
  add_action "INSTALL_USAGE_RULES"
fi

# intent/llm/MODULES.md -- plant canonical seed if absent (audit showed 9
# fleet projects need this).
if [ -f "$PROJECT_DIR/intent/llm/MODULES.md" ]; then
  canon_print "intent/llm/MODULES.md" "${GREEN}PRESENT${NC}"
else
  canon_print "intent/llm/MODULES.md" "${RED}MISSING${NC}"
  add_action "PLANT_MODULES"
fi

# intent/llm/DECISION_TREE.md -- plant canonical seed if absent.
if [ -f "$PROJECT_DIR/intent/llm/DECISION_TREE.md" ]; then
  canon_print "intent/llm/DECISION_TREE.md" "${GREEN}PRESENT${NC}"
else
  canon_print "intent/llm/DECISION_TREE.md" "${RED}MISSING${NC}"
  add_action "PLANT_DECISION_TREE"
fi

# intent/.treeindex/.treeindexignore -- install canonical default if absent.
# Canon excludes intent/.config/cache/ + backup/ but keeps config.json indexed
# (ST0036/WP-06). Existing files left alone (project-customisable).
if [ -f "$PROJECT_DIR/intent/.treeindex/.treeindexignore" ]; then
  canon_print "intent/.treeindex/.treeindexignore" "${GREEN}PRESENT${NC} (project-owned)"
else
  canon_print "intent/.treeindex/.treeindexignore" "${RED}MISSING${NC}"
  add_action "INSTALL_TREEINDEXIGNORE"
fi

# Legacy intent/llm/AGENTS.md -- delete if present (canon moved to root in
# v2.10.0; most projects already caught up via WP-10).
if [ -f "$PROJECT_DIR/intent/llm/AGENTS.md" ] || [ -L "$PROJECT_DIR/intent/llm/AGENTS.md" ]; then
  canon_print "intent/llm/AGENTS.md" "${YELLOW}LEGACY (will delete)${NC}"
  add_action "DELETE_LEGACY_AGENTS"
fi

# .gitignore -- ensure canon-managed entries are present and in canonical form.
# Replaces overly-broad .claude (whole directory) with .claude/settings.local.json
# so the canon session hooks (settings.json, scripts/*) are tracked. Also adds
# /AGENTS.md.bak (regen safety net). Skipped if .gitignore is absent.
if [ -f "$PROJECT_DIR/.gitignore" ]; then
  if canon_gitignore_needs_normalize "$PROJECT_DIR/.gitignore"; then
    canon_print ".gitignore" "${YELLOW}NORMALIZE${NC} (.claude/ + /AGENTS.md.bak entries)"
    add_action "NORMALIZE_GITIGNORE"
  else
    canon_print ".gitignore" "${GREEN}OK${NC} (canon entries present and canonical)"
  fi
else
  canon_print ".gitignore" "${BLUE}absent (skipped)${NC}"
fi

# ============================================================
# PHASE 2: PLAN
# ============================================================

echo ""
echo -e "${BOLD}Phase 2: Upgrade Plan${NC}"
echo ""

if [ ${#ACTIONS[@]} -eq 0 ] && [ ${#WARNINGS[@]} -eq 0 ]; then
  echo -e "${GREEN}No changes needed. Project is up to date.${NC}"
  exit 0
fi

if [ ${#ACTIONS[@]} -gt 0 ]; then
  echo "Actions to perform:"
  idx=1
  for action in "${ACTIONS[@]}"; do
    # Pretty-print action codes
    case "$action" in
      VERSION_BUMP:*)
        old_ver="${action#VERSION_BUMP:}"
        old_ver="${old_ver%%:*}"
        new_ver="${action##*:}"
        echo "  $idx. Update intent_version: $old_ver -> $new_ver"
        ;;
      RENAME_SKILL:*)
        old_name="${action#RENAME_SKILL:}"
        old_name="${old_name%%:*}"
        new_name="${action##*:}"
        echo "  $idx. Rename skill: $old_name -> $new_name"
        ;;
      UPDATE_SUBAGENT:*)
        sa_name="${action#UPDATE_SUBAGENT:}"
        echo "  $idx. Update subagent: $sa_name"
        ;;
      UPDATE_SKILL:*)
        sk_name="${action#UPDATE_SKILL:}"
        echo "  $idx. Update skill: $sk_name"
        ;;
      INSTALL_SETTINGS)
        echo "  $idx. Install .claude/settings.json (SessionStart / UserPromptSubmit / Stop hooks)"
        ;;
      INSTALL_HOOK_SCRIPT:*)
        sh_name="${action#INSTALL_HOOK_SCRIPT:}"
        echo "  $idx. Install .claude/scripts/$sh_name (+x)"
        ;;
      INSTALL_PRE_COMMIT)
        echo "  $idx. Install .git/hooks/pre-commit (intent critic gate, +x)"
        ;;
      CHAIN_PRE_COMMIT)
        echo "  $idx. Install .git/hooks/pre-commit.intent and chain it from existing pre-commit (idempotent block)"
        ;;
      CHAIN_PRE_COMMIT_BLOCK)
        echo "  $idx. Insert intent-chain-block into existing .git/hooks/pre-commit (idempotent)"
        ;;
      INSTALL_CRITIC_CONFIG)
        echo "  $idx. Install .intent_critic.yml (severity defaults)"
        ;;
      INSTALL_CLAUDE_MD)
        if [ -f "$PROJECT_DIR/CLAUDE.md" ] && [ "$FORCE" = true ]; then
          echo "  $idx. Overwrite root CLAUDE.md with canon (--force; user content lost)"
        else
          echo "  $idx. Install root CLAUDE.md (Claude overlay pointing at AGENTS.md)"
        fi
        ;;
      REFRESH_CLAUDE_MD)
        echo "  $idx. Refresh root CLAUDE.md (preserve user section between markers)"
        if [ "$DRY_RUN" = true ] && [ -f "$PROJECT_DIR/CLAUDE.md" ]; then
          _diff_preview="$(mktemp)"
          canon_compute_refresh_preview "$CANON_CLAUDE_MD_SRC" "$PROJECT_DIR/CLAUDE.md" "$_diff_preview"
          _diff_lines="$(diff -u "$PROJECT_DIR/CLAUDE.md" "$_diff_preview" 2>/dev/null | wc -l | tr -d '[:space:]')"
          if [ "${_diff_lines:-0}" -gt 0 ]; then
            echo "       diff (current vs after refresh, first 60 lines):"
            diff -u "$PROJECT_DIR/CLAUDE.md" "$_diff_preview" 2>/dev/null \
              | head -60 \
              | sed 's/^/         /'
          fi
          rm -f "$_diff_preview"
        fi
        ;;
      INSTALL_USAGE_RULES)
        echo "  $idx. Install root usage-rules.md (terse DO / NEVER contract)"
        ;;
      PLANT_MODULES)
        echo "  $idx. Plant intent/llm/MODULES.md (Highlander registry seed)"
        ;;
      PLANT_DECISION_TREE)
        echo "  $idx. Plant intent/llm/DECISION_TREE.md (code-placement flow chart seed)"
        ;;
      INSTALL_TREEINDEXIGNORE)
        echo "  $idx. Install intent/.treeindex/.treeindexignore (canonical exclusions)"
        ;;
      DELETE_LEGACY_AGENTS)
        echo "  $idx. Delete legacy intent/llm/AGENTS.md (canon moved to root in v2.10.0)"
        ;;
      *)
        echo "  $idx. $action"
        ;;
    esac
    idx=$((idx + 1))
  done
fi

if [ ${#WARNINGS[@]} -gt 0 ]; then
  echo ""
  echo "Manual review needed:"
  for warning in "${WARNINGS[@]}"; do
    echo -e "  ${YELLOW}!${NC} $warning"
  done
fi

# ============================================================
# PHASE 3: EXECUTE (if --apply)
# ============================================================

if [ "$DRY_RUN" = true ]; then
  echo ""
  echo -e "${BOLD}$(printf '%.0s-' {1..60})${NC}"
  echo -e "${YELLOW}Dry-run complete. Review the plan above.${NC}"
  echo ""
  echo "To apply these changes:"
  echo "  intent claude upgrade --apply"
  if [ "$PROJECT_DIR" != "$(pwd)" ]; then
    echo "  intent claude upgrade --project-dir $PROJECT_DIR --apply"
  fi
  exit 0
fi

echo ""
echo -e "${BOLD}Phase 3: Applying Changes${NC}"
echo ""

# Execute each action
for action in "${ACTIONS[@]}"; do
  case "$action" in
    VERSION_BUMP:*)
      new_ver="${action##*:}"
      echo "  Updating intent_version to $new_ver..."
      if [ -f "$PROJECT_DIR/intent/.config/config.json" ]; then
        sed -i '' "s/\"intent_version\": *\"[^\"]*\"/\"intent_version\": \"$new_ver\"/" "$PROJECT_DIR/intent/.config/config.json"
        echo -e "    ${GREEN}ok:${NC} intent/.config/config.json updated"
      fi
      # Update CLAUDE.md version references if present
      if [ -f "$PROJECT_DIR/CLAUDE.md" ]; then
        sed -i '' "s/Intent v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*/Intent v$new_ver/g" "$PROJECT_DIR/CLAUDE.md"
        echo -e "    ${GREEN}ok:${NC} CLAUDE.md version references updated"
      fi
      ;;

    "DELETE intent/llm/llm_preamble.md")
      echo "  Deleting intent/llm/llm_preamble.md..."
      rm -f "$PROJECT_DIR/intent/llm/llm_preamble.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    "DELETE intent/llm/usage-rules.md")
      echo "  Deleting intent/llm/usage-rules.md..."
      rm -f "$PROJECT_DIR/intent/llm/usage-rules.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    "DELETE intent/llm/AGENTS-phx.md"*)
      echo "  Deleting intent/llm/AGENTS-phx.md..."
      rm -f "$PROJECT_DIR/intent/llm/AGENTS-phx.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    REGENERATE*)
      echo "  Regenerating AGENTS.md (via intent agents sync)..."
      if ( cd "$PROJECT_DIR" && "$INTENT_BIN/intent" agents sync >/dev/null 2>&1 ); then
        echo -e "    ${GREEN}ok${NC}"
      else
        echo -e "    ${YELLOW}warning${NC}: intent agents sync exited non-zero; leaving AGENTS.md as-is"
      fi
      ;;

    "CREATE AGENTS.md"*)
      echo "  Creating AGENTS.md (via intent agents sync)..."
      if ( cd "$PROJECT_DIR" && "$INTENT_BIN/intent" agents sync >/dev/null 2>&1 ); then
        echo -e "    ${GREEN}ok${NC}"
      else
        echo -e "    ${YELLOW}warning${NC}: intent agents sync exited non-zero; AGENTS.md not written"
      fi
      ;;

    "CREATE intent/llm/RULES.md"*)
      echo "  Creating intent/llm/RULES.md..."
      mkdir -p "$PROJECT_DIR/intent/llm"
      cp "$TEMPLATES_SOURCE/RULES.md" "$PROJECT_DIR/intent/llm/RULES.md"
      echo -e "    ${GREEN}ok${NC} (customize for your project)"
      ;;

    "CREATE intent/llm/ARCHITECTURE.md"*)
      echo "  Creating intent/llm/ARCHITECTURE.md..."
      mkdir -p "$PROJECT_DIR/intent/llm"
      cp "$TEMPLATES_SOURCE/ARCHITECTURE.md" "$PROJECT_DIR/intent/llm/ARCHITECTURE.md"
      echo -e "    ${GREEN}ok${NC} (fill in project-specific content)"
      ;;

    "MERGE intent/llm/AGENTS-phx.md"*)
      echo "  AGENTS-phx.md merge requires manual review."
      echo -e "    ${YELLOW}hint:${NC} Merge Phoenix rules into RULES.md manually"
      ;;

    RENAME_SKILL:*)
      old_name="${action#RENAME_SKILL:}"
      old_name="${old_name%%:*}"
      new_name="${action##*:}"
      echo "  Renaming skill $old_name -> $new_name..."
      if [ -d "$SKILLS_SOURCE/$new_name" ]; then
        rm -rf "$HOME/.claude/skills/$old_name"
        mkdir -p "$HOME/.claude/skills/$new_name"
        cp -r "$SKILLS_SOURCE/$new_name/"* "$HOME/.claude/skills/$new_name/"
        echo -e "    ${GREEN}ok${NC}"
      else
        echo -e "    ${YELLOW}skipped${NC} (source skill $new_name not found)"
      fi
      ;;

    UPDATE_SUBAGENT:*)
      sa_name="${action#UPDATE_SUBAGENT:}"
      echo "  Updating subagent $sa_name..."
      cp "$SUBAGENTS_SOURCE/$sa_name/agent.md" "$HOME/.claude/agents/$sa_name.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    UPDATE_SKILL:*)
      sk_name="${action#UPDATE_SKILL:}"
      echo "  Updating skill $sk_name..."
      mkdir -p "$HOME/.claude/skills/$sk_name"
      cp -r "$SKILLS_SOURCE/$sk_name/"* "$HOME/.claude/skills/$sk_name/"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    INSTALL_SETTINGS)
      echo "  Installing .claude/settings.json..."
      canon_install_file "$CANON_SETTINGS_SRC" "$PROJECT_DIR/.claude/settings.json"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    INSTALL_HOOK_SCRIPT:*)
      sh_name="${action#INSTALL_HOOK_SCRIPT:}"
      echo "  Installing .claude/scripts/$sh_name..."
      canon_install_script "$CANON_SCRIPTS_SRC/$sh_name" "$PROJECT_DIR/.claude/scripts/$sh_name"
      echo -e "    ${GREEN}ok${NC} (+x)"
      ;;

    INSTALL_PRE_COMMIT)
      if [ -z "$PRE_COMMIT_PATH" ] || [ -z "$PRE_COMMIT_INTENT_PATH" ]; then
        echo -e "  ${YELLOW}skipped${NC}: cannot resolve git hooks dir (no .git or git unavailable)"
      else
        echo "  Installing $PRE_COMMIT_INTENT_PATH (canon body)..."
        canon_install_script "$CANON_PRE_COMMIT_SRC" "$PRE_COMMIT_INTENT_PATH"
        echo "  Installing $PRE_COMMIT_PATH (chain stub)..."
        cat > "$PRE_COMMIT_PATH" <<'PRECOMMIT'
#!/usr/bin/env bash
set -u
PRECOMMIT
        chmod +x "$PRE_COMMIT_PATH"
        canon_insert_chain_block "$PRE_COMMIT_PATH"
        echo -e "    ${GREEN}ok${NC} (chained architecture; severity threshold from .intent_critic.yml)"
      fi
      ;;

    CHAIN_PRE_COMMIT)
      if [ -z "$PRE_COMMIT_INTENT_PATH" ] || [ -z "$PRE_COMMIT_PATH" ]; then
        echo -e "  ${YELLOW}skipped${NC}: cannot resolve git hooks dir (no .git or git unavailable)"
      else
        echo "  Installing $PRE_COMMIT_INTENT_PATH..."
        canon_install_script "$CANON_PRE_COMMIT_SRC" "$PRE_COMMIT_INTENT_PATH"
        echo -e "    ${GREEN}ok${NC} (existing hook preserved)"
        echo "  Inserting intent-chain-block into $PRE_COMMIT_PATH..."
        canon_insert_chain_block "$PRE_COMMIT_PATH"
        echo -e "    ${GREEN}ok${NC} (idempotent; pre-commit now invokes pre-commit.intent)"
      fi
      ;;

    CHAIN_PRE_COMMIT_BLOCK)
      if [ -z "$PRE_COMMIT_PATH" ]; then
        echo -e "  ${YELLOW}skipped${NC}: cannot resolve git hooks dir (no .git or git unavailable)"
      else
        echo "  Inserting intent-chain-block into $PRE_COMMIT_PATH..."
        canon_insert_chain_block "$PRE_COMMIT_PATH"
        echo -e "    ${GREEN}ok${NC} (idempotent; pre-commit now invokes pre-commit.intent)"
      fi
      ;;

    MIGRATE_LEGACY_PRE_COMMIT)
      if [ -z "$PRE_COMMIT_INTENT_PATH" ] || [ -z "$PRE_COMMIT_PATH" ]; then
        echo -e "  ${YELLOW}skipped${NC}: cannot resolve git hooks dir (no .git or git unavailable)"
      else
        if [ ! -f "$PRE_COMMIT_INTENT_PATH" ]; then
          echo "  Migrating legacy single-file pre-commit (canon body -> pre-commit.intent)..."
          mv "$PRE_COMMIT_PATH" "$PRE_COMMIT_INTENT_PATH"
        else
          echo "  pre-commit.intent already present; replacing pre-commit with chain stub..."
          rm -f "$PRE_COMMIT_PATH"
        fi
        cat > "$PRE_COMMIT_PATH" <<'PRECOMMIT'
#!/usr/bin/env bash
set -u
PRECOMMIT
        chmod +x "$PRE_COMMIT_PATH"
        canon_insert_chain_block "$PRE_COMMIT_PATH"
        echo -e "    ${GREEN}ok${NC} (canon body at pre-commit.intent; pre-commit chain stub generated)"
      fi
      ;;

    INSTALL_CRITIC_CONFIG)
      echo "  Installing .intent_critic.yml..."
      canon_install_file "$CANON_CRITIC_YML_SRC" "$PROJECT_DIR/.intent_critic.yml"
      echo -e "    ${GREEN}ok${NC} (severity_min=warning; edit to tune)"
      ;;

    NORMALIZE_GITIGNORE)
      echo "  Normalizing .gitignore (.claude/ + /AGENTS.md.bak entries)..."
      canon_normalize_gitignore "$PROJECT_DIR/.gitignore"
      echo -e "    ${GREEN}ok${NC} (canon files now tracked; settings.local.json + AGENTS.md.bak ignored)"
      ;;

    INSTALL_CLAUDE_MD)
      echo "  Installing root CLAUDE.md..."
      canon_install_file "$CANON_CLAUDE_MD_SRC" "$PROJECT_DIR/CLAUDE.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    REFRESH_CLAUDE_MD)
      echo "  Refreshing root CLAUDE.md (preserving user section)..."
      canon_refresh_with_user_section "$CANON_CLAUDE_MD_SRC" "$PROJECT_DIR/CLAUDE.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    INSTALL_USAGE_RULES)
      echo "  Installing root usage-rules.md..."
      canon_install_file "$CANON_USAGE_RULES_SRC" "$PROJECT_DIR/usage-rules.md"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    PLANT_MODULES)
      echo "  Planting intent/llm/MODULES.md..."
      canon_install_file "$CANON_MODULES_SRC" "$PROJECT_DIR/intent/llm/MODULES.md"
      echo -e "    ${GREEN}ok${NC} (seed; populate as you register modules)"
      ;;

    PLANT_DECISION_TREE)
      echo "  Planting intent/llm/DECISION_TREE.md..."
      canon_install_file "$CANON_DECISION_TREE_SRC" "$PROJECT_DIR/intent/llm/DECISION_TREE.md"
      echo -e "    ${GREEN}ok${NC} (seed; adapt to your project)"
      ;;

    INSTALL_TREEINDEXIGNORE)
      echo "  Installing intent/.treeindex/.treeindexignore..."
      canon_install_file "$CANON_TREEINDEXIGNORE_SRC" "$PROJECT_DIR/intent/.treeindex/.treeindexignore"
      echo -e "    ${GREEN}ok${NC}"
      ;;

    DELETE_LEGACY_AGENTS)
      echo "  Deleting legacy intent/llm/AGENTS.md..."
      canon_delete_file "$PROJECT_DIR/intent/llm/AGENTS.md"
      echo -e "    ${GREEN}ok${NC} (canonical location is project root since v2.10.0)"
      ;;

    *)
      echo -e "  ${YELLOW}skipped: $action${NC}"
      ;;
  esac
done

echo ""
echo -e "${BOLD}$(printf '%.0s-' {1..60})${NC}"
echo -e "${GREEN}Upgrade applied successfully.${NC}"

if [ ${#WARNINGS[@]} -gt 0 ]; then
  echo ""
  echo "Remaining manual tasks:"
  for warning in "${WARNINGS[@]}"; do
    echo -e "  ${YELLOW}!${NC} $warning"
  done
fi

echo ""
echo "Next steps:"
echo "  1. Review generated files and customize for your project"
echo "  2. Run 'intent doctor' to verify configuration"
echo "  3. Commit changes"
