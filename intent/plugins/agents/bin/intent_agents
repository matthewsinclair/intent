#!/bin/bash
# intent_agents - Manage AGENTS.md for Intent projects
# Copyright (c) 2026 Matthew Sinclair
# Licensed under the MIT License (see LICENSE file)
# Commands: init, generate, sync, validate, template
#
# Note: `set -e` deferred (see WP12 dogfood Entry 1) -- subcommands signal
# status via non-zero exit; strict mode would abort prematurely.

# Source helpers from main bin directory
PLUGIN_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INTENT_ROOT="$(cd "$PLUGIN_BIN/../../../.." && pwd)"
INTENT_BIN="$INTENT_ROOT/bin"
source "$INTENT_BIN/intent_helpers"

# Plugin paths
PLUGIN_DIR="$INTENT_ROOT/intent/plugins/agents"
TEMPLATES_DIR="$PLUGIN_DIR/templates"

# Show help
intent_agents_help() {
  cat << EOF
Usage: intent agents <command> [options]

Manage AGENTS.md for Intent projects -- the primary tool-agnostic LLM config
file at project root. Read by Claude Code, Codex, Cursor, Copilot, Aider,
Continue, Cline, Gemini CLI, and other agentic tools.

Commands:
  init        Initialize AGENTS.md at project root
  generate    Emit generated AGENTS.md content to stdout
  sync        Regenerate AGENTS.md from current project state
  validate    Validate AGENTS.md shape and required sections
  template    Manage AGENTS.md templates

Examples:
  intent agents init                     # Create initial AGENTS.md (auto-generated)
  intent agents init --template elixir   # Initial from the elixir template
  intent agents sync                     # Regenerate with latest project state
  intent agents validate                 # Check AGENTS.md compliance
  intent agents template list            # List available templates

For help on a specific command:
  intent help agents <command>
EOF
}

# Replace a legacy root-level AGENTS.md symlink (old canon:
# root -> intent/llm/AGENTS.md) so a real file can take its place. Idempotent.
_replace_symlink_if_present() {
  if [ -L "$PROJECT_ROOT/AGENTS.md" ]; then
    rm -f "$PROJECT_ROOT/AGENTS.md"
  fi
}

# Extract the `description:` scalar from YAML frontmatter of a markdown file.
# Used by the installed-skills and installed-subagents section renderers.
_extract_frontmatter_description() {
  local file="$1"
  [ -f "$file" ] || return 0
  awk '
    /^---[[:space:]]*$/ { c++; if (c == 2) exit; next }
    c == 1 && /^description:[[:space:]]*/ {
      sub(/^description:[[:space:]]*/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$file" 2>/dev/null
}

# Render "Installed Skills" section body. Reads .claude/skills/*/SKILL.md.
_render_installed_skills() {
  local skills_dir="$PROJECT_ROOT/.claude/skills"
  if [ ! -d "$skills_dir" ]; then
    echo "_No skills installed. Run \`intent claude skills list\` to see available skills._"
    return
  fi
  local found=false
  local skill name desc
  for skill in "$skills_dir"/*/; do
    [ -d "$skill" ] || continue
    name=$(basename "$skill")
    desc=""
    if [ -f "$skill/SKILL.md" ]; then
      desc=$(_extract_frontmatter_description "$skill/SKILL.md")
    fi
    if [ -n "$desc" ]; then
      echo "- **$name** -- $desc"
    else
      echo "- **$name**"
    fi
    found=true
  done
  if [ "$found" = false ]; then
    echo "_No skills installed. Run \`intent claude skills list\` to see available skills._"
  fi
}

# Render "Installed Subagents" section body. Reads .claude/agents/*.md.
_render_installed_subagents() {
  local agents_dir="$PROJECT_ROOT/.claude/agents"
  if [ ! -d "$agents_dir" ]; then
    echo "_No subagents installed. Run \`intent claude subagents list\` to see available subagents._"
    return
  fi
  local found=false
  local agent name desc
  for agent in "$agents_dir"/*.md; do
    [ -f "$agent" ] || continue
    name=$(basename "$agent" .md)
    desc=$(_extract_frontmatter_description "$agent")
    if [ -n "$desc" ]; then
      echo "- **$name** -- $desc"
    else
      echo "- **$name**"
    fi
    found=true
  done
  if [ "$found" = false ]; then
    echo "_No subagents installed. Run \`intent claude subagents list\` to see available subagents._"
  fi
}

# Initialize AGENTS.md at project root.
intent_agents_init() {
  echo "Initializing AGENTS.md for Intent project..."

  # Load config if needed and require project context
  if [ -z "${PROJECT_ROOT:-}" ] && [ -f "$INTENT_BIN/intent_config" ]; then
    source "$INTENT_BIN/intent_config"
    load_intent_config
  fi
  require_project_root || return 1

  # Parse arguments
  local force=false
  local template=""
  local prev_was_template=""
  local arg
  for arg in "$@"; do
    if [ "$arg" = "--force" ] || [ "$arg" = "-f" ]; then
      force=true
    elif [[ "$arg" == --template=* ]]; then
      template="${arg#--template=}"
    elif [ -n "$prev_was_template" ]; then
      template="$arg"
      prev_was_template=""
    elif [ "$arg" = "--template" ]; then
      prev_was_template=true
    fi
  done

  # A pre-existing regular file at root blocks unless --force. A symlink
  # from the old canon is transparent -- we replace it.
  if [ -f "$PROJECT_ROOT/AGENTS.md" ] && [ ! -L "$PROJECT_ROOT/AGENTS.md" ] && [ "$force" = false ]; then
    echo "AGENTS.md already exists. Use --force to overwrite or 'intent agents sync' to update."
    return 1
  fi

  _replace_symlink_if_present

  if [ -n "$template" ]; then
    local template_dir="$TEMPLATES_DIR/$template"
    if [ ! -d "$template_dir" ]; then
      echo "Error: Template '$template' not found"
      echo "Available templates:"
      for tdir in "$TEMPLATES_DIR"/*/; do
        [ -d "$tdir" ] && echo "  - $(basename "$tdir")"
      done
      return 1
    fi

    # AGENTS.md lands at project root. Sibling templates (RULES.md,
    # ARCHITECTURE.md) remain under intent/llm/ as human-curated files.
    if [ -f "$template_dir/AGENTS.md" ]; then
      cp "$template_dir/AGENTS.md" "$PROJECT_ROOT/AGENTS.md"
      echo "  Created AGENTS.md from $template template"
    fi

    mkdir -p "$PROJECT_ROOT/intent/llm"

    if [ -f "$template_dir/RULES.md" ]; then
      if [ ! -f "$PROJECT_ROOT/intent/llm/RULES.md" ] || [ "$force" = true ]; then
        cp "$template_dir/RULES.md" "$PROJECT_ROOT/intent/llm/RULES.md"
        echo "  Created intent/llm/RULES.md from $template template"
      else
        echo "  intent/llm/RULES.md already exists (skipped -- human-curated)"
      fi
    fi

    if [ -f "$template_dir/ARCHITECTURE.md" ]; then
      if [ ! -f "$PROJECT_ROOT/intent/llm/ARCHITECTURE.md" ] || [ "$force" = true ]; then
        cp "$template_dir/ARCHITECTURE.md" "$PROJECT_ROOT/intent/llm/ARCHITECTURE.md"
        echo "  Created intent/llm/ARCHITECTURE.md from $template template"
      else
        echo "  intent/llm/ARCHITECTURE.md already exists (skipped -- human-curated)"
      fi
    fi
  else
    intent_agents_generate_content > "$PROJECT_ROOT/AGENTS.md"
  fi

  echo ""
  echo "Created AGENTS.md at project root."
  echo ""
  echo "AGENTS.md is the primary tool-agnostic LLM config file."
  echo "Run 'intent agents sync' to regenerate with the latest project state."

  if [ -n "$template" ]; then
    echo ""
    echo "Template '$template' applied. Customize:"
    echo "  AGENTS.md                    -- project overview, commands, setup (root)"
    echo "  intent/llm/RULES.md          -- coding rules (human-curated)"
    echo "  intent/llm/ARCHITECTURE.md   -- system architecture (human-curated)"
  fi
}

# Generate AGENTS.md content to stdout.
intent_agents_generate_content() {
  local project_name=$(basename "$PROJECT_ROOT")
  local has_package_json=false
  local has_mix_exs=false
  local has_cargo_toml=false
  local has_makefile=false
  local has_bats=false
  local test_command=""
  local build_command=""

  # Detect project type and commands from language markers.
  if [ -f "$PROJECT_ROOT/package.json" ]; then
    has_package_json=true
    test_command=$(jq -r '.scripts.test // ""' "$PROJECT_ROOT/package.json" 2>/dev/null)
    build_command=$(jq -r '.scripts.build // ""' "$PROJECT_ROOT/package.json" 2>/dev/null)
  fi

  if [ -f "$PROJECT_ROOT/mix.exs" ]; then
    has_mix_exs=true
    [ -z "$test_command" ] && test_command="mix test"
    [ -z "$build_command" ] && build_command="mix compile"
  fi

  if [ -f "$PROJECT_ROOT/Cargo.toml" ]; then
    has_cargo_toml=true
    [ -z "$test_command" ] && test_command="cargo test"
    [ -z "$build_command" ] && build_command="cargo build"
  fi

  if [ -f "$PROJECT_ROOT/Makefile" ]; then
    has_makefile=true
    [ -z "$test_command" ] && test_command="make test"
    [ -z "$build_command" ] && build_command="make build"
  fi

  if [ -d "$PROJECT_ROOT/tests" ] && find "$PROJECT_ROOT/tests" -name "*.bats" -type f -print -quit 2>/dev/null | grep -q .; then
    has_bats=true
    [ -z "$test_command" ] && test_command="bats -r tests/"
  fi

  cat << 'EOF'
# AGENTS.md

This is the primary tool-agnostic config file for AI coding agents working on this project. Every major agentic CLI (Claude Code, Codex, Cursor, Copilot, Aider, Continue, Cline, Gemini CLI) reads AGENTS.md as the canonical project contract. Spec: https://agents.md.

## Project Overview

EOF

  if [ -f "$PROJECT_ROOT/CLAUDE.md" ]; then
    echo "$project_name -- an Intent project. See \`CLAUDE.md\` for Claude-specific overlay."
  else
    echo "$project_name -- an Intent project using the Steel Thread Process methodology."
  fi

  cat << 'EOF'

## Development Environment

### Prerequisites

EOF

  if [ "$has_mix_exs" = true ]; then
    echo "- Elixir / Erlang / OTP (see \`mix.exs\` for version)"
  fi
  if [ "$has_cargo_toml" = true ]; then
    echo "- Rust toolchain (see \`Cargo.toml\` for edition)"
  fi
  if [ "$has_package_json" = true ]; then
    echo "- Node.js + npm/yarn"
  fi
  if [ "$has_bats" = true ]; then
    echo "- Bats testing framework"
  fi
  echo "- Bash 4.0+, POSIX-compliant shell"

  cat << 'EOF'

### Setup

```bash
intent doctor     # verify Intent configuration
```

EOF

  if [ "$has_mix_exs" = true ]; then
    cat << 'EOF'
```bash
mix setup         # deps.get + ecto.setup (if configured)
iex -S mix        # interactive shell
```

EOF
  fi

  if [ "$has_cargo_toml" = true ]; then
    cat << 'EOF'
```bash
cargo build
cargo run
```

EOF
  fi

  if [ "$has_package_json" = true ]; then
    cat << 'EOF'
```bash
npm install
```

EOF
  fi

  cat << 'EOF'
## Build and Test Commands

### Testing

EOF

  if [ -n "$test_command" ]; then
    echo '```bash'
    echo "$test_command"
    echo '```'
  else
    echo "_No automated tests configured yet._"
  fi

  cat << 'EOF'

### Building

EOF

  if [ -n "$build_command" ]; then
    echo '```bash'
    echo "$build_command"
    echo '```'
  else
    echo "_No build step required._"
  fi

  cat << 'EOF'

### Validation

```bash
intent doctor       # check Intent configuration
intent st list      # list steel threads
```

## Code Style

EOF

  if [ "$has_mix_exs" = true ]; then
    echo "- Follow Elixir conventions enforced by \`mix format\`."
  fi
  if [ "$has_cargo_toml" = true ]; then
    echo "- Follow Rust conventions enforced by \`cargo fmt\`."
  fi

  cat << 'EOF'
- Shell scripts: 2-space indentation, POSIX-compliant where practical.
- Markdown: no manual line wrapping; verblock frontmatter on persistent docs.
- See `usage-rules.md` for the terse "DO / NEVER" contract.
- See `intent/docs/working-with-llms.md` for the canon tech note on the LLM-facing layout and how hooks + critics + skills compose.

## Steel Thread + Work Package Process

Work is organised into numbered **steel threads** (`ST####`), each containing **work packages** (`WP`). Every steel thread has its own directory under `intent/st/<ID>/` with `info.md` as the entry point.

```bash
intent st list               # list steel threads
intent st new "Title"        # create new
intent st show <id>          # inspect
intent wp list <STID>        # list work packages
intent wp new <STID> "..."   # create work package
intent wp start <STID/NN>    # mark WIP
intent wp done <STID/NN>     # mark done
```

Never create steel thread or work package directories by hand -- always use the CLI.

## Installed Skills

EOF

  _render_installed_skills

  cat << 'EOF'

## Installed Subagents

EOF

  _render_installed_subagents

  cat << 'EOF'

## Critic Family

Per-language rule enforcement via thin subagents that read the rule library at invocation time. Available: `critic-elixir`, `critic-rust`, `critic-swift`, `critic-lua`, `critic-shell`. Invoke:

```
Task(subagent_type="critic-<lang>", prompt="review <targets>")
```

A headless runner at `bin/intent_critic` (Greppable-proxy rules only; no LLM required) powers the pre-commit gate. Contract: `intent/docs/critics.md`. Exit codes: `0` clean, `1` findings, `2` error.

## Rule Library

All coding rules live in `intent/plugins/claude/rules/`. Each rule is a markdown file with YAML frontmatter, a Detection heuristic, and bad/good examples. Skills cite rule IDs; critics enforce them.

```bash
intent claude rules list        # enumerate
intent claude rules show <id>   # inspect
intent claude rules validate    # schema check
```

## Extensions

User extensions live at `~/.intent/ext/<name>/` and contribute subagents, skills, or rule packs without modifying canon. Reference extension: `worker-bee`.

```bash
intent ext list
intent ext show <name>
intent ext new <name>
```

Authoring guide: `intent/docs/writing-extensions.md`.

## Session Hooks

`.claude/settings.json` wires three Claude Code lifecycle hooks: **SessionStart** (inject context + `/in-session` reminder), **UserPromptSubmit** (strict gate -- block first prompt until `/in-session` runs), **Stop** (remind `/in-finish` at wrap-up). Full architecture: `intent/docs/working-with-llms.md#session-hook-architecture`.

## Socrates vs Diogenes FAQ

Two distinct subagents for two distinct concerns:

- **Socrates** -- CTO Review Mode. Architectural and strategic technical decision-making via Socratic dialog.
- **Diogenes** -- Elixir Test Architect. Test-specification generation and gap analysis.

They have never been the same agent. FAQ + forensic detail: `intent/docs/working-with-llms.md#socrates-vs-diogenes-faq`.

## Testing Instructions

1. Run the test suite before making changes -- establish a baseline.
2. Make changes.
3. Run the suite again; confirm no regressions.
4. Add new tests for new functionality.
5. Before commit, the pre-commit critic gate checks staged files for `CRITICAL` + `WARNING` findings. See `intent/docs/pre-commit-hook.md`.

## Commit Guidelines

- Descriptive commit messages; reference steel thread or work package IDs where applicable.
- No AI attribution in commit messages (no `Co-Authored-By`, no tool signatures).
- Small, coherent commits preferred over large batches.

## Security Considerations

- Never commit secrets or credentials.
- Review external inputs for injection-class bugs.
- Follow the project's security policy if one exists.

## Additional Resources

- `intent/docs/working-with-llms.md` -- canon tech note (narrative).
- `intent/docs/critics.md` -- critic contract.
- `intent/docs/rules.md` -- rule library authoring guide.
- `intent/docs/writing-extensions.md` -- extension author guide.
- `intent/docs/pre-commit-hook.md` -- pre-commit critic gate install + configure.
- `intent/llm/MODULES.md` -- module registry (Highlander enforcement).
EOF

  if [ -f "$PROJECT_ROOT/CLAUDE.md" ]; then
    echo "- \`CLAUDE.md\` -- Claude-specific overlay."
  fi
  if [ -f "$PROJECT_ROOT/usage-rules.md" ]; then
    echo "- \`usage-rules.md\` -- DO / NEVER contract for this project."
  fi

  echo ""
  echo "---"
  echo "_Generated by Intent v$(get_intent_version) on $(date '+%Y-%m-%d')_"
}

# Sync AGENTS.md with latest project state.
intent_agents_sync() {
  echo "Syncing AGENTS.md with latest project state..."

  if [ -z "${PROJECT_ROOT:-}" ] && [ -f "$INTENT_BIN/intent_config" ]; then
    source "$INTENT_BIN/intent_config"
    load_intent_config
  fi
  require_project_root || return 1

  # Handle legacy symlink (old canon: root -> intent/llm/AGENTS.md).
  _replace_symlink_if_present

  # Backup existing real file if present.
  if [ -f "$PROJECT_ROOT/AGENTS.md" ]; then
    cp "$PROJECT_ROOT/AGENTS.md" "$PROJECT_ROOT/AGENTS.md.bak"
  fi

  intent_agents_generate_content > "$PROJECT_ROOT/AGENTS.md"

  echo "ok: AGENTS.md updated at project root."
  if [ -f "$PROJECT_ROOT/AGENTS.md.bak" ]; then
    echo "    previous version saved to AGENTS.md.bak"
  fi
}

# Validate AGENTS.md.
intent_agents_validate() {
  echo "Validating AGENTS.md..."

  if [ -z "${PROJECT_ROOT:-}" ] && [ -f "$INTENT_BIN/intent_config" ]; then
    source "$INTENT_BIN/intent_config"
    load_intent_config
  fi
  require_project_root || return 1

  local errors=0
  local warnings=0

  if [ ! -e "$PROJECT_ROOT/AGENTS.md" ]; then
    echo "error: AGENTS.md not found at project root"
    ((++errors))
  elif [ -L "$PROJECT_ROOT/AGENTS.md" ]; then
    echo "warn: AGENTS.md is a symlink (legacy canon). Run 'intent agents sync' to replace with a real file."
    ((++warnings))
  elif [ ! -f "$PROJECT_ROOT/AGENTS.md" ]; then
    echo "error: AGENTS.md exists but is not a regular file"
    ((++errors))
  else
    echo "ok: AGENTS.md found at project root (regular file)"

    local required_sections=(
      "Project Overview"
      "Development Environment"
      "Build and Test Commands"
      "Code Style"
    )

    local section
    for section in "${required_sections[@]}"; do
      if grep -q "## $section" "$PROJECT_ROOT/AGENTS.md" 2>/dev/null; then
        echo "ok: has section: $section"
      else
        echo "warn: missing recommended section: $section"
        ((++warnings))
      fi
    done
  fi

  echo ""
  if [ $errors -eq 0 ] && [ $warnings -eq 0 ]; then
    echo "ok: AGENTS.md validation passed"
  elif [ $errors -eq 0 ]; then
    echo "ok: AGENTS.md is valid with $warnings warning(s)"
  else
    echo "error: AGENTS.md validation failed with $errors error(s) and $warnings warning(s)"
    return 1
  fi
}

# Template management.
intent_agents_template() {
  local subcommand="${1:-list}"
  shift

  case "$subcommand" in
    list)
      echo "Available AGENTS.md templates:"
      local tdir
      for tdir in "$TEMPLATES_DIR"/*/; do
        [ -d "$tdir" ] && echo "  - $(basename "$tdir")"
      done
      ;;
    show)
      local template_name="${1:-}"
      if [ -z "$template_name" ]; then
        echo "error: template name required"
        echo "Usage: intent agents template show <name>"
        return 1
      fi
      local template_file="$TEMPLATES_DIR/$template_name/AGENTS.md"
      if [ -f "$template_file" ]; then
        cat "$template_file"
      else
        echo "error: template '$template_name' not found"
        return 1
      fi
      ;;
    *)
      echo "Unknown template subcommand: $subcommand"
      echo "Usage: intent agents template [list|show <name>]"
      return 1
      ;;
  esac
}

# Main command dispatcher - only run if script is executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  case "${1:-}" in
    init)
      shift
      intent_agents_init "$@"
      ;;
    generate|regenerate)
      shift
      intent_agents_generate_content
      ;;
    sync|update)
      shift
      intent_agents_sync "$@"
      ;;
    validate|check)
      shift
      intent_agents_validate "$@"
      ;;
    template|templates)
      shift
      intent_agents_template "$@"
      ;;
    help|--help|-h|"")
      intent_agents_help
      ;;
    *)
      echo "Unknown command: $1"
      intent_agents_help
      exit 1
      ;;
  esac
fi
